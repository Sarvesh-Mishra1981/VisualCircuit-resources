1001.0504155158997, "y": 375.42536973953247}], "labels": [], "width": 3, "color": "gray", "curvyness": 50, "selectedColor": "rgb(0,192,255)"}, "07179b71-66ee-4c0e-a1f8-144189b264db": {"id": "07179b71-66ee-4c0e-a1f8-144189b264db", "type": "default", "selected": false, "source": "fcff4760-d0de-47d5-a622-c7592a8b6d04", "sourcePort": "b61ebd42-a212-4677-860c-0c2783de5529", "target": null, "targetPort": null, "points": [{"id": "7f86a34f-ed63-46a8-a256-e5092762c242", "type": "point", "x": 1403.1337895393372, "y": 263.7586827278137}, {"id": "0dffe732-33ea-4fd3-b2b4-b24bcbd328b8", "type": "point", "selected": false, "x": 1227, "y": 627.0069427490234}, {"id": "4148a73b-017d-403c-a867-dbd683090863", "type": "point", "x": 1205, "y": 654.0069427490234}], "labels": [], "width": 3, "color": "gray", "curvyness": 50, "selectedColor": "rgb(0,192,255)"}, "001ed324-acdc-406e-bf07-bdc76f8c75fc": {"id": "001ed324-acdc-406e-bf07-bdc76f8c75fc", "type": "default", "selected": false, "source": "fcff4760-d0de-47d5-a622-c7592a8b6d04", "sourcePort": "b61ebd42-a212-4677-860c-0c2783de5529", "target": "fda8b232-6cd3-4306-970e-06cf63f203cd", "targetPort": "f6102e89-c5b8-4938-90ee-425385d72284", "points": [{"id": "53b0bfe7-22ee-45ba-a67c-254072a2de9e", "type": "point", "x": 1403.1337895393372, "y": 263.7586827278137}, {"id": "9c739aca-929d-4c27-a87f-dc5e2950495a", "type": "point", "x": 1109.6093754768372, "y": 648.3160252571106}], "labels": [], "width": 3, "color": "gray", "curvyness": 50, "selectedColor": "rgb(0,192,255)"}, "783aa9cd-884b-4a17-a727-94de6324b88e": {"id": "783aa9cd-884b-4a17-a727-94de6324b88e", "type": "default", "selected": true, "source": "fcff4760-d0de-47d5-a622-c7592a8b6d04", "sourcePort": "7124336c-9570-4b63-b83b-2d0e5e403146", "target": "fda8b232-6cd3-4306-970e-06cf63f203cd", "targetPort": "8f1f0411-1ec3-452d-90af-b82a3d62b454", "points": [{"id": "a8d110c4-14b4-4259-8ce0-155e54f64f28", "type": "point", "x": 1403.1337895393372, "y": 379.31425523757935}, {"id": "6619524e-c440-49c8-adc6-a364fcdbd9df", "type": "point", "x": 1109.6093754768372, "y": 763.8715672492981}], "labels": [], "width": 3, "color": "gray", "curvyness": 50, "selectedColor": "rgb(0,192,255)"}, "f14cbb06-5bce-4b11-924d-09c40c0145a8": {"id": "f14cbb06-5bce-4b11-924d-09c40c0145a8", "type": "default", "source": "fcff4760-d0de-47d5-a622-c7592a8b6d04", "sourcePort": "7124336c-9570-4b63-b83b-2d0e5e403146", "target": "2c667aad-7093-4ea8-ab3e-abe08135474a", "targetPort": "a846c110-5cc7-48d2-ad8c-95fdf4704117", "points": [{"id": "d0b6ad60-607b-4ce1-826a-a70b65ed047f", "type": "point", "x": 1403.1337895393372, "y": 379.31425523757935}, {"id": "eb37283d-fe7c-404d-8a90-124cf045432d", "type": "point", "x": 108.05555624868339, "y": 125.99826883973671}], "labels": [], "width": 3, "color": "gray", "curvyness": 50, "selectedColor": "rgb(0,192,255)"}}}, {"id": "a1dde559-b16e-4c9c-a4ec-49ce44a2bebd", "type": "diagram-nodes", "isSvg": false, "transformed": true, "models": {"a41b9299-9ca0-44ef-b6bf-9a80d484eda2": {"id": "a41b9299-9ca0-44ef-b6bf-9a80d484eda2", "type": "basic.code", "x": 100, "y": 100, "ports": [{"id": "662dad3a-78d0-4ae9-ba67-a12cf0716932", "type": "port.output", "x": 697.5521240234375, "y": 207.3697967529297, "name": "laser_ready", "alignment": "right", "parentNode": "48cdb8f9-e7dc-4e20-ac70-33a8a47c8e54", "links": ["e63e9331-a536-4654-a550-457d11eacdbd"], "in": false, "label": "laser_ready", "hideLabel": false}, {"id": "f1dc2516-a85a-40e9-9464-e0fad23b3f2a", "type": "port.output", "x": 697.5521240234375, "y": 283.7066192626953, "name": "ranges", "alignment": "right", "parentNode": "48cdb8f9-e7dc-4e20-ac70-33a8a47c8e54", "links": ["3e63a69f-c843-407c-a62e-bd6dd4b16fe2"], "in": false, "label": "ranges", "hideLabel": false}, {"id": "03ce72c7-b73b-492a-8947-75d7aca607b1", "type": "port.output", "x": 697.5521240234375, "y": 348.3680877685547, "name": "angle_min", "alignment": "right", "parentNode": "48cdb8f9-e7dc-4e20-ac70-33a8a47c8e54", "links": ["d9d7b09f-2e7b-44f7-8418-689614aecc64"], "in": false, "label": "angle_min", "hideLabel": false}, {"id": "88ca62fe-a0f6-4182-9219-d31ed4cb8a1e", "type": "port.output", "x": 697.5521240234375, "y": 413.03822326660156, "name": "angle_increment", "alignment": "right", "parentNode": "48cdb8f9-e7dc-4e20-ac70-33a8a47c8e54", "links": ["67be822e-ace6-4a09-b54e-25ee5498978f"], "in": false, "label": "angle_increment", "hideLabel": false}], "data": {"code": "import rclpy\nfrom rclpy.node import Node\nfrom rclpy.qos import qos_profile_sensor_data\nfrom sensor_msgs.msg import LaserScan\n\n\ndef write_output(outputs, name, value):\n    if hasattr(outputs, \"write\"):\n        outputs.write(name, value)\n        return\n    if hasattr(outputs, \"set\"):\n        outputs.set(name, value)\n        return\n    try:\n        outputs[name] = value\n        return\n    except Exception:\n        pass\n    setattr(outputs, name, value)\n\n\ndef main(inputs, outputs, parameters, synchronise):\n    if not rclpy.ok():\n        rclpy.init(args=None)\n\n    class LaserBlock(Node):\n        def __init__(self):\n            super().__init__(\"vc_laser_scan_reader\")\n\n            self.laser_ready = False\n            self.ranges = []\n            self.angle_min = 0.0\n            self.angle_increment = 0.0\n\n            self.create_subscription(\n                LaserScan,\n                \"/turtlebot3/laser/scan\",\n                self.scan_callback,\n                qos_profile_sensor_data,\n            )\n\n        def scan_callback(self, msg):\n            self.laser_ready = True\n            self.ranges = list(msg.ranges)\n            self.angle_min = msg.angle_min\n            self.angle_increment = msg.angle_increment\n\n    node = LaserBlock()\n\n    while True:\n        rclpy.spin_once(node, timeout_sec=0.0)\n\n        write_output(outputs, \"laser_ready\", node.laser_ready)\n        write_output(outputs, \"ranges\", node.ranges)\n        write_output(outputs, \"angle_min\", node.angle_min)\n        write_output(outputs, \"angle_increment\", node.angle_increment)\n\n        synchronise()", "frequency": "30", "params": [], "ports": {"in": [], "out": [{"name": "laser_ready"}, {"name": "ranges"}, {"name": "angle_min"}, {"name": "angle_increment"}]}, "size": {"width": "542px", "height": "300px"}}}, "d185885f-5d83-409f-bdfe-c798e089fa30": {"id": "d185885f-5d83-409f-bdfe-c798e089fa30", "type": "basic.code", "selected": false, "x": 522, "y": 98, "ports": [{"id": "447e2ac4-5080-4639-9f26-8c8144c6fcf7", "type": "port.input", "x": 522.5521240234375, "y": 205.36460876464844, "name": "laser_ready", "alignment": "left", "parentNode": "13b27369-710f-4ab3-9855-73a66f2085b4", "links": ["e63e9331-a536-4654-a550-457d11eacdbd"], "in": true, "label": "laser_ready", "hideLabel": false}, {"id": "a04b4a68-334c-4c43-bcbc-1e7a9ae378a0", "type": "port.input", "x": 522.5521240234375, "y": 281.70140075683594, "name": "ranges", "alignment": "left", "parentNode": "13b27369-710f-4ab3-9855-73a66f2085b4", "links": ["3e63a69f-c843-407c-a62e-bd6dd4b16fe2"], "in": true, "label": "ranges", "hideLabel": false}, {"id": "f7db3299-bbda-4044-9222-663d2bd49ac9", "type": "port.input", "x": 522.5521240234375, "y": 346.3628692626953, "name": "angle_min", "alignment": "left", "parentNode": "13b27369-710f-4ab3-9855-73a66f2085b4", "links": ["d9d7b09f-2e7b-44f7-8418-689614aecc64"], "in": true, "label": "angle_min", "hideLabel": false}, {"id": "9bb3c951-21e5-45f4-96e9-02c3d4d9760a", "type": "port.input", "x": 522.5521240234375, "y": 411.0330047607422, "name": "angle_increment", "alignment": "left", "parentNode": "13b27369-710f-4ab3-9855-73a66f2085b4", "links": ["67be822e-ace6-4a09-b54e-25ee5498978f"], "in": true, "label": "angle_increment", "hideLabel": false}, {"id": "813b0dcf-31f5-4c85-b278-42417a5fbbba", "type": "port.output", "x": 927.5521240234375, "y": 248.4809112548828, "name": "distance_ready", "alignment": "right", "parentNode": "13b27369-710f-4ab3-9855-73a66f2085b4", "links": ["7c7161c3-8e4e-45fe-ba2e-388c68faf8fc"], "in": false, "label": "distance_ready", "hideLabel": false}, {"id": "f9e091d7-5080-4947-a47d-a4aeca394dc3", "type": "port.output", "x": 927.5521240234375, "y": 367.9253692626953, "name": "front_distance", "alignment": "right", "parentNode": "13b27369-710f-4ab3-9855-73a66f2085b4", "links": ["11d407d8-2c84-463a-9e60-ed4034cbe1c4"], "in": false, "label": "front_distance", "hideLabel": false}], "data": {"code": "import math\n\n\ndef read_input(inputs, name, default=None):\n    if hasattr(inputs, \"read\"):\n        return inputs.read(name)\n    if hasattr(inputs, \"get\"):\n        return inputs.get(name, default)\n    try:\n        return inputs[name]\n    except Exception:\n        return getattr(inputs, name, default)\n\n\ndef write_output(outputs, name, value):\n    if hasattr(outputs, \"write\"):\n        outputs.write(name, value)\n        return\n    if hasattr(outputs, \"set\"):\n        outputs.set(name, value)\n        return\n    try:\n        outputs[name] = value\n        return\n    except Exception:\n        pass\n    setattr(outputs, name, value)\n\n\ndef main(inputs, outputs, parameters, synchronise):\n    front_width = 0.35\n\n    while True:\n        laser_ready = read_input(inputs, \"laser_ready\", False)\n        ranges = read_input(inputs, \"ranges\", [])\n        angle_min = read_input(inputs, \"angle_min\", 0.0)\n        angle_increment = read_input(inputs, \"angle_increment\", 0.0)\n\n        front_distance = 10.0\n\n        if laser_ready and ranges is not None:\n            values = []\n\n            for i, dist in enumerate(ranges):\n                angle = angle_min + i * angle_increment\n\n                if -front_width <= angle <= front_width:\n                    if math.isfinite(dist) and dist > 0.05:\n                        values.append(dist)\n\n            if values:\n                front_distance = min(values)\n\n        write_output(outputs, \"front_distance\", front_distance)\n\n        synchronise()", "frequency": "30", "params": [], "ports": {"in": [{"name": "laser_ready"}, {"name": "ranges"}, {"name": "angle_min"}, {"name": "angle_increment"}], "out": [{"name": "distance_ready"}, {"name": "front_distance"}]}, "size": {"width": "300px", "height": "300px"}}}, "ec973abb-8878-413c-8503-a144496e5a81": {"id": "ec973abb-8878-413c-8503-a144496e5a81", "type": "basic.code", "selected": false, "x": 993, "y": 98, "ports": [{"id": "200a9159-fbc7-4ba6-b289-fbef9eee4891", "type": "port.input", "x": 993.5504150390625, "y": 248.4809112548828, "name": "distance_ready", "alignment": "left", "parentNode": "fcff4760-d0de-47d5-a622-c7592a8b6d04", "links": ["7c7161c3-8e4e-45fe-ba2e-388c68faf8fc"], "in": true, "label": "distance_ready", "hideLabel": false}, {"id": "545bd6f3-07b1-4316-b1c3-ffe6184caab7", "type": "port.input", "x": 993.5504150390625, "y": 367.9253692626953, "name": "front_distance", "alignment": "left", "parentNode": "fcff4760-d0de-47d5-a622-c7592a8b6d04", "links": ["11d407d8-2c84-463a-9e60-ed4034cbe1c4"], "in": true, "label": "front_distance", "hideLabel": false}, {"id": "b61ebd42-a212-4677-860c-0c2783de5529", "type": "port.output", "x": 1395.6337890625, "y": 256.25868225097656, "name": "linear_x", "alignment": "right", "parentNode": "fcff4760-d0de-47d5-a622-c7592a8b6d04", "links": ["07179b71-66ee-4c0e-a1f8-144189b264db", "001ed324-acdc-406e-bf07-bdc76f8c75fc"], "in": false, "label": "linear_x", "hideLabel": false}, {"id": "7124336c-9570-4b63-b83b-2d0e5e403146", "type": "port.output", "x": 1395.6337890625, "y": 371.8142547607422, "name": "angular_z", "alignment": "right", "parentNode": "fcff4760-d0de-47d5-a622-c7592a8b6d04", "links": ["783aa9cd-884b-4a17-a727-94de6324b88e", "f14cbb06-5bce-4b11-924d-09c40c0145a8"], "in": false, "label": "angular_z", "hideLabel": false}], "data": {"code": "def read_input(inputs, name, default=None):\n    if hasattr(inputs, \"read\"):\n        return inputs.read(name)\n    if hasattr(inputs, \"get\"):\n        return inputs.get(name, default)\n    try:\n        return inputs[name]\n    except Exception:\n        return getattr(inputs, name, default)\n\n\ndef write_output(outputs, name, value):\n    if hasattr(outputs, \"write\"):\n        outputs.write(name, value)\n        return\n    if hasattr(outputs, \"set\"):\n        outputs.set(name, value)\n        return\n    try:\n        outputs[name] = value\n        return\n    except Exception:\n        pass\n    setattr(outputs, name, value)\n\n\ndef main(inputs, outputs, parameters, synchronise):\n    state = \"FORWARD\"\n\n    forward_speed = 0.16\n    turn_speed = 0.45\n\n    front_stop_distance = 0.60\n    front_clear_distance = 0.90\n\n    while True:\n        front_distance = read_input(inputs, \"front_distance\", 10.0)\n\n        if front_distance is None:\n            front_distance = 10.0\n\n        linear_x = 0.0\n        angular_z = 0.0\n\n        if state == \"FORWARD\":\n            if front_distance < front_stop_distance:\n                state = \"TURN_LEFT\"\n                linear_x = 0.0\n                angular_z = turn_speed\n            else:\n                linear_x = forward_speed\n                angular_z = 0.0\n\n        elif state == \"TURN_LEFT\":\n            linear_x = 0.0\n            angular_z = turn_speed\n\n            if front_distance > front_clear_distance:\n                state = \"FORWARD\"\n                linear_x = forward_speed\n                angular_z = 0.0\n\n        write_output(outputs, \"linear_x\", linear_x)\n        write_output(outputs, \"angular_z\", angular_z)\n        write_output(outputs, \"state\", state)\n\n        synchronise()", "frequency": "30", "params": [], "ports": {"in": [{"name": "distance_ready"}, {"name": "front_distance"}], "out": [{"name": "linear_x"}, {"name": "angular_z"}]}, "size": {"width": "300px", "height": "300px"}}}, "0b7bceb2-0c4e-4a23-bdad-81a183bb0f9b": {"id": "0b7bceb2-0c4e-4a23-bdad-81a183bb0f9b", "type": "basic.code", "selected": true, "x": 1101, "y": 482, "ports": [{"id": "f6102e89-c5b8-4938-90ee-425385d72284", "type": "port.input", "x": 1102.109375, "y": 640.8160247802734, "name": "linear_x", "alignment": "left", "parentNode": "fda8b232-6cd3-4306-970e-06cf63f203cd", "links": ["001ed324-acdc-406e-bf07-bdc76f8c75fc"], "in": true, "label": "linear_x", "hideLabel": false}, {"id": "8f1f0411-1ec3-452d-90af-b82a3d62b454", "type": "port.input", "x": 1102.109375, "y": 756.3715667724609, "name": "angular_z", "alignment": "left", "parentNode": "fda8b232-6cd3-4306-970e-06cf63f203cd", "links": ["783aa9cd-884b-4a17-a727-94de6324b88e"], "in": true, "label": "angular_z", "hideLabel": false}], "data": {"code": "import rclpy\nfrom rclpy.node import Node\nfrom geometry_msgs.msg import Twist\n\n\ndef read_input(inputs, name, default=None):\n    if hasattr(inputs, \"read\"):\n        return inputs.read(name)\n    if hasattr(inputs, \"get\"):\n        return inputs.get(name, default)\n    try:\n        return inputs[name]\n    except Exception:\n        return getattr(inputs, name, default)\n\n\ndef main(inputs, outputs, parameters, synchronise):\n    if not rclpy.ok():\n        rclpy.init(args=None)\n\n    class CmdVelBlock(Node):\n        def __init__(self):\n            super().__init__(\"vc_cmd_vel_publisher\")\n            self.pub = self.create_publisher(Twist, \"/turtlebot3/cmd_vel\", 10)\n\n        def publish_cmd(self, linear_x, angular_z):\n            msg = Twist()\n            msg.linear.x = float(linear_x)\n            msg.angular.z = float(angular_z)\n            self.pub.publish(msg)\n\n    node = CmdVelBlock()\n\n    while True:\n        linear_x = read_input(inputs, \"linear_x\", 0.0)\n        angular_z = read_input(inputs, \"angular_z\", 0.0)\n\n        if linear_x is None:\n            linear_x = 0.0\n\n        if angular_z is None:\n            angular_z = 0.0\n\n        node.publish_cmd(linear_x, angular_z)\n\n        synchronise()", "frequency": "30", "params": [], "ports": {"in": [{"name": "linear_x"}, {"name": "angular_z"}], "out": []}, "size": {"width": "300px", "height": "300px"}}}, "a7ee7690-fbd7-45d9-a9f0-4a0ea532827e": {"id": "a7ee7690-fbd7-45d9-a9f0-4a0ea532827e", "type": "basic.output", "x": 100, "y": 100, "ports": [{"id": "a846c110-5cc7-48d2-ad8c-95fdf4704117", "type": "port.input", "x": 100.555557167767, "y": 118.49826548391054, "name": "output-in", "alignment": "left", "parentNode": "2c667aad-7093-4ea8-ab3e-abe08135474a", "links": ["f14cbb06-5bce-4b11-924d-09c40c0145a8"], "in": true, "label": "output-in", "hideLabel": true}], "data": {"name": "angular_z"}}}}]}, "info": {"name": "Line Follower PID", "version": "1.0.0", "description": "A robust PID controller block.", "author": "Sarvesh Mishra", "category": "Control Systems", "tags": ["pid", "line follower", "control"], "image": ""}, "design": {"board": "Python3-Noetic", "graph": {"blocks": [{"id": "a41b9299-9ca0-44ef-b6bf-9a80d484eda2", "type": "basic.code", "data": {"code": "import rclpy\nfrom rclpy.node import Node\nfrom rclpy.qos import qos_profile_sensor_data\nfrom sensor_msgs.msg import LaserScan\n\n\ndef write_output(outputs, name, value):\n    if hasattr(outputs, \"write\"):\n        outputs.write(name, value)\n        return\n    if hasattr(outputs, \"set\"):\n        outputs.set(name, value)\n        return\n    try:\n        outputs[name] = value\n        return\n    except Exception:\n        pass\n    setattr(outputs, name, value)\n\n\ndef main(inputs, outputs, parameters, synchronise):\n    if not rclpy.ok():\n        rclpy.init(args=None)\n\n    class LaserBlock(Node):\n        def __init__(self):\n            super().__init__(\"vc_laser_scan_reader\")\n\n            self.laser_ready = False\n            self.ranges = []\n            self.angle_min = 0.0\n            self.angle_increment = 0.0\n\n            self.create_subscription(\n                LaserScan,\n                \"/turtlebot3/laser/scan\",\n                self.scan_callback,\n                qos_profile_sensor_data,\n            )\n\n        def scan_callback(self, msg):\n            self.laser_ready = True\n            self.ranges = list(msg.ranges)\n            self.angle_min = msg.angle_min\n            self.angle_increment = msg.angle_increment\n\n    node = LaserBlock()\n\n    while True:\n        rclpy.spin_once(node, timeout_sec=0.0)\n\n        write_output(outputs, \"laser_ready\", node.laser_ready)\n        write_output(outputs, \"ranges\", node.ranges)\n        write_output(outputs, \"angle_min\", node.angle_min)\n        write_output(outputs, \"angle_increment\", node.angle_increment)\n\n        synchronise()", "frequency": "30", "params": [], "ports": {"in": [], "out": [{"name": "laser_ready"}, {"name": "ranges"}, {"name": "angle_min"}, {"name": "angle_increment"}]}, "size": {"width": "542px", "height": "300px"}}, "position": {"x": 100, "y": 100}}, {"id": "d185885f-5d83-409f-bdfe-c798e089fa30", "type": "basic.code", "data": {"code": "import math\n\n\ndef read_input(inputs, name, default=None):\n    if hasattr(inputs, \"read\"):\n        return inputs.read(name)\n    if hasattr(inputs, \"get\"):\n        return inputs.get(name, default)\n    try:\n        return inputs[name]\n    except Exception:\n        return getattr(inputs, name, default)\n\n\ndef write_output(outputs, name, value):\n    if hasattr(outputs, \"write\"):\n        outputs.write(name, value)\n        return\n    if hasattr(outputs, \"set\"):\n        outputs.set(name, value)\n        return\n    try:\n        outputs[name] = value\n        return\n    except Exception:\n        pass\n    setattr(outputs, name, value)\n\n\ndef main(inputs, outputs, parameters, synchronise):\n    front_width = 0.35\n\n    while True:\n        laser_ready = read_input(inputs, \"laser_ready\", False)\n        ranges = read_input(inputs, \"ranges\", [])\n        angle_min = read_input(inputs, \"angle_min\", 0.0)\n        angle_increment = read_input(inputs, \"angle_increment\", 0.0)\n\n        front_distance = 10.0\n\n        if laser_ready and ranges is not None:\n            values = []\n\n            for i, dist in enumerate(ranges):\n                angle = angle_min + i * angle_increment\n\n                if -front_width <= angle <= front_width:\n                    if math.isfinite(dist) and dist > 0.05:\n                        values.append(dist)\n\n            if values:\n                front_distance = min(values)\n\n        write_output(outputs, \"front_distance\", front_distance)\n\n        synchronise()", "frequency": "30", "params": [], "ports": {"in": [{"name": "laser_ready"}, {"name": "ranges"}, {"name": "angle_min"}, {"name": "angle_increment"}], "out": [{"name": "distance_ready"}, {"name": "front_distance"}]}, "size": {"width": "300px", "height": "300px"}}, "position": {"x": 522, "y": 98}}, {"id": "ec973abb-8878-413c-8503-a144496e5a81", "type": "basic.code", "data": {"code": "def read_input(inputs, name, default=None):\n    if hasattr(inputs, \"read\"):\n        return inputs.read(name)\n    if hasattr(inputs, \"get\"):\n        return inputs.get(name, default)\n    try:\n        return inputs[name]\n    except Exception:\n        return getattr(inputs, name, default)\n\n\ndef write_output(outputs, name, value):\n    if hasattr(outputs, \"write\"):\n        outputs.write(name, value)\n        return\n    if hasattr(outputs, \"set\"):\n        outputs.set(name, value)\n        return\n    try:\n        outputs[name] = value\n        return\n    except Exception:\n        pass\n    setattr(outputs, name, value)\n\n\ndef main(inputs, outputs, parameters, synchronise):\n    state = \"FORWARD\"\n\n    forward_speed = 0.16\n    turn_speed = 0.45\n\n    front_stop_distance = 0.60\n    front_clear_distance = 0.90\n\n    while True:\n        front_distance = read_input(inputs, \"front_distance\", 10.0)\n\n        if front_distance is None:\n            front_distance = 10.0\n\n        linear_x = 0.0\n        angular_z = 0.0\n\n        if state == \"FORWARD\":\n            if front_distance < front_stop_distance:\n                state = \"TURN_LEFT\"\n                linear_x = 0.0\n                angular_z = turn_speed\n            else:\n                linear_x = forward_speed\n                angular_z = 0.0\n\n        elif state == \"TURN_LEFT\":\n            linear_x = 0.0\n            angular_z = turn_speed\n\n            if front_distance > front_clear_distance:\n                state = \"FORWARD\"\n                linear_x = forward_speed\n                angular_z = 0.0\n\n        write_output(outputs, \"linear_x\", linear_x)\n        write_output(outputs, \"angular_z\", angular_z)\n        write_output(outputs, \"state\", state)\n\n        synchronise()", "frequency": "30", "params": [], "ports": {"in": [{"name": "distance_ready"}, {"name": "front_distance"}], "out": [{"name": "linear_x"}, {"name": "angular_z"}]}, "size": {"width": "300px", "height": "300px"}}, "position": {"x": 993, "y": 98}}, {"id": "0b7bceb2-0c4e-4a23-bdad-81a183bb0f9b", "type": "basic.code", "data": {"code": "import rclpy\nfrom rclpy.node import Node\nfrom geometry_msgs.msg import Twist\n\n\ndef read_input(inputs, name, default=None):\n    if hasattr(inputs, \"read\"):\n        return inputs.read(name)\n    if hasattr(inputs, \"get\"):\n        return inputs.get(name, default)\n    try:\n        return inputs[name]\n    except Exception:\n        return getattr(inputs, name, default)\n\n\ndef main(inputs, outputs, parameters, synchronise):\n    if not rclpy.ok():\n        rclpy.init(args=None)\n\n    class CmdVelBlock(Node):\n        def __init__(self):\n            super().__init__(\"vc_cmd_vel_publisher\")\n            self.pub = self.create_publisher(Twist, \"/turtlebot3/cmd_vel\", 10)\n\n        def publish_cmd(self, linear_x, angular_z):\n            msg = Twist()\n            msg.linear.x = float(linear_x)\n            msg.angular.z = float(angular_z)\n            self.pub.publish(msg)\n\n    node = CmdVelBlock()\n\n    while True:\n        linear_x = read_input(inputs, \"linear_x\", 0.0)\n        angular_z = read_input(inputs, \"angular_z\", 0.0)\n\n        if linear_x is None:\n            linear_x = 0.0\n\n        if angular_z is None:\n            angular_z = 0.0\n\n        node.publish_cmd(linear_x, angular_z)\n\n        synchronise()", "frequency": "30", "params": [], "ports": {"in": [{"name": "linear_x"}, {"name": "angular_z"}], "out": []}, "size": {"width": "300px", "height": "300px"}}, "position": {"x": 1101, "y": 482}}, {"id": "a7ee7690-fbd7-45d9-a9f0-4a0ea532827e", "type": "basic.output", "data": {"name": "angular_z"}, "position": {"x": 100, "y": 100}}], "wires": [{"source": {"block": "a41b9299-9ca0-44ef-b6bf-9a80d484eda2", "port": "laser_ready", "name": "laser_ready"}, "target": {"block": "d185885f-5d83-409f-bdfe-c798e089fa30", "port": "laser_ready", "name": "laser_ready"}}, {"source": {"block": "a41b9299-9ca0-44ef-b6bf-9a80d484eda2", "port": "ranges", "name": "ranges"}, "target": {"block": "d185885f-5d83-409f-bdfe-c798e089fa30", "port": "ranges", "name": "ranges"}}, {"source": {"block": "a41b9299-9ca0-44ef-b6bf-9a80d484eda2", "port": "angle_min", "name": "angle_min"}, "target": {"block": "d185885f-5d83-409f-bdfe-c798e089fa30", "port": "angle_min", "name": "angle_min"}}, {"source": {"block": "a41b9299-9ca0-44ef-b6bf-9a80d484eda2", "port": "angle_increment", "name": "angle_increment"}, "target": {"block": "d185885f-5d83-409f-bdfe-c798e089fa30", "port": "angle_increment", "name": "angle_increment"}}, {"source": {"block": "d185885f-5d83-409f-bdfe-c798e089fa30", "port": "distance_ready", "name": "distance_ready"}, "target": {"block": "ec973abb-8878-413c-8503-a144496e5a81", "port": "distance_ready", "name": "distance_ready"}}, {"source": {"block": "d185885f-5d83-409f-bdfe-c798e089fa30", "port": "front_distance", "name": "front_distance"}, "target": {"block": "ec973abb-8878-413c-8503-a144496e5a81", "port": "front_distance", "name": "front_distance"}}, {"source": {"block": "ec973abb-8878-413c-8503-a144496e5a81", "port": "linear_x", "name": "linear_x"}, "target": {"block": "0b7bceb2-0c4e-4a23-bdad-81a183bb0f9b", "port": "linear_x", "name": "linear_x"}}, {"source": {"block": "ec973abb-8878-413c-8503-a144496e5a81", "port": "angular_z", "name": "angular_z"}, "target": {"block": "0b7bceb2-0c4e-4a23-bdad-81a183bb0f9b", "port": "angular_z", "name": "angular_z"}}, {"source": {"block": "ec973abb-8878-413c-8503-a144496e5a81", "port": "angular_z", "name": "angular_z"}, "target": {"block": "a7ee7690-fbd7-45d9-a9f0-4a0ea532827e", "port": "output-in", "name": "output-in"}}]}}, "dependencies": {}}}}]}, "version": "3.0", "package": {"name": "Line Follower PID", "version": "1.0.0", "description": "A robust PID controller block.", "author": "Sarvesh Mishra _1981", "image": "", "category": "Machine Learning", "tags": ["pid", "line follower", "control"]}, "design": {"board": "Python3-Noetic", "graph": {"blocks": [{"id": "2ff0697c-424f-4ed1-9b17-51d3d6297134", "type": "basic.code", "data": {"code": "import rclpy\nfrom rclpy.node import Node\nfrom rclpy.qos import qos_profile_sensor_data\nfrom sensor_msgs.msg import LaserScan\n\n\ndef write_output(outputs, name, value):\n    if hasattr(outputs, \"write\"):\n        outputs.write(name, value)\n        return\n    if hasattr(outputs, \"set\"):\n        outputs.set(name, value)\n        return\n    try:\n        outputs[name] = value\n        return\n    except Exception:\n        pass\n    setattr(outputs, name, value)\n\n\ndef main(inputs, outputs, parameters, synchronise):\n    if not rclpy.ok():\n        rclpy.init(args=None)\n\n    class LaserBlock(Node):\n        def __init__(self):\n            super().__init__(\"vc_laser_scan_reader\")\n\n            self.laser_ready = False\n            self.ranges = []\n            self.angle_min = 0.0\n            self.angle_increment = 0.0\n\n            self.create_subscription(\n                LaserScan,\n                \"/turtlebot3/laser/scan\",\n                self.scan_callback,\n                qos_profile_sensor_data,\n            )\n\n        def scan_callback(self, msg):\n            self.laser_ready = True\n            self.ranges = list(msg.ranges)\n            self.angle_min = msg.angle_min\n            self.angle_increment = msg.angle_increment\n\n    node = LaserBlock()\n\n    while True:\n        rclpy.spin_once(node, timeout_sec=0.0)\n\n        write_output(outputs, \"laser_ready\", node.laser_ready)\n        write_output(outputs, \"ranges\", node.ranges)\n        write_output(outputs, \"angle_min\", node.angle_min)\n        write_output(outputs, \"angle_increment\", node.angle_increment)\n\n        synchronise()", "frequency": "30", "params": [], "ports": {"in": [], "out": [{"name": "laser_ready"}, {"name": "ranges"}, {"name": "angle_min"}, {"name": "angle_increment"}]}, "size": {"width": "300px", "height": "300px"}}, "position": {"x": 100, "y": 100}}, {"id": "19775c67-2fa0-42aa-8938-1396ec00ac2a", "type": "basic.code", "data": {"code": "import math\n\n\ndef read_input(inputs, name, default=None):\n    if hasattr(inputs, \"read\"):\n        return inputs.read(name)\n    if hasattr(inputs, \"get\"):\n        return inputs.get(name, default)\n    try:\n        return inputs[name]\n    except Exception:\n        return getattr(inputs, name, default)\n\n\ndef write_output(outputs, name, value):\n    if hasattr(outputs, \"write\"):\n        outputs.write(name, value)\n        return\n    if hasattr(outputs, \"set\"):\n        outputs.set(name, value)\n        return\n    try:\n        outputs[name] = value\n        return\n    except Exception:\n        pass\n    setattr(outputs, name, value)\n\n\ndef main(inputs, outputs, parameters, synchronise):\n    front_width = 0.35\n\n    while True:\n        laser_ready = read_input(inputs, \"laser_ready\", False)\n        ranges = read_input(inputs, \"ranges\", [])\n        angle_min = read_input(inputs, \"angle_min\", 0.0)\n        angle_increment = read_input(inputs, \"angle_increment\", 0.0)\n\n        front_distance = 10.0\n\n        if laser_ready and ranges is not None:\n            values = []\n\n            for i, dist in enumerate(ranges):\n                angle = angle_min + i * angle_increment\n\n                if -front_width <= angle <= front_width:\n                    if math.isfinite(dist) and dist > 0.05:\n                        values.append(dist)\n\n            if values:\n                front_distance = min(values)\n\n        write_output(outputs, \"front_distance\", front_distance)\n\n        synchronise()", "frequency": "30", "params": [], "ports": {"in": [{"name": "laser_ready"}, {"name": "ranges"}, {"name": "angle_min"}, {"name": "angle_increment"}], "out": [{"name": "distance_ready"}, {"name": "front_distance"}]}, "size": {"width": "361px", "height": "300px"}}, "position": {"x": 274.9607083817433, "y": 128.8799114522821}}, {"id": "52d347cf-d852-4356-8cb0-13f48e935367", "type": "basic.code", "data": {"code": "def read_input(inputs, name, default=None):\n    if hasattr(inputs, \"read\"):\n        return inputs.read(name)\n    if hasattr(inputs, \"get\"):\n        return inputs.get(name, default)\n    try:\n        return inputs[name]\n    except Exception:\n        return getattr(inputs, name, default)\n\n\ndef write_output(outputs, name, value):\n    if hasattr(outputs, \"write\"):\n        outputs.write(name, value)\n        return\n    if hasattr(outputs, \"set\"):\n        outputs.set(name, value)\n        return\n    try:\n        outputs[name] = value\n        return\n    except Exception:\n        pass\n    setattr(outputs, name, value)\n\n\ndef main(inputs, outputs, parameters, synchronise):\n    state = \"FORWARD\"\n\n    forward_speed = 0.16\n    turn_speed = 0.45\n\n    front_stop_distance = 0.60\n    front_clear_distance = 0.90\n\n    while True:\n        front_distance = read_input(inputs, \"front_distance\", 10.0)\n\n        if front_distance is None:\n            front_distance = 10.0\n\n        linear_x = 0.0\n        angular_z = 0.0\n\n        if state == \"FORWARD\":\n            if front_distance < front_stop_distance:\n                state = \"TURN_LEFT\"\n                linear_x = 0.0\n                angular_z = turn_speed\n            else:\n                linear_x = forward_speed\n                angular_z = 0.0\n\n        elif state == \"TURN_LEFT\":\n            linear_x = 0.0\n            angular_z = turn_speed\n\n            if front_distance > front_clear_distance:\n                state = \"FORWARD\"\n                linear_x = forward_speed\n                angular_z = 0.0\n\n        write_output(outputs, \"linear_x\", linear_x)\n        write_output(outputs, \"angular_z\", angular_z)\n        write_output(outputs, \"state\", state)\n\n        synchronise()", "frequency": "30", "params": [], "ports": {"in": [{"name": "distance_ready"}, {"name": "front_distance"}], "out": [{"name": "linear_x"}, {"name": "angular_z"}]}, "size": {"width": "300px", "height": "300px"}}, "position": {"x": 1075.6784725980456, "y": -9.581626995047273}}, {"id": "19991c8c-f0ad-4b9d-adb2-9d81080b6bec", "type": "basic.code", "data": {"code": "import rclpy\nfrom rclpy.node import Node\nfrom geometry_msgs.msg import Twist\n\n\ndef read_input(inputs, name, default=None):\n    if hasattr(inputs, \"read\"):\n        return inputs.read(name)\n    if hasattr(inputs, \"get\"):\n        return inputs.get(name, default)\n    try:\n        return inputs[name]\n    except Exception:\n        return getattr(inputs, name, default)\n\n\ndef main(inputs, outputs, parameters, synchronise):\n    if not rclpy.ok():\n        rclpy.init(args=None)\n\n    class CmdVelBlock(Node):\n        def __init__(self):\n            super().__init__(\"vc_cmd_vel_publisher\")\n            self.pub = self.create_publisher(Twist, \"/turtlebot3/cmd_vel\", 10)\n\n        def publish_cmd(self, linear_x, angular_z):\n            msg = Twist()\n            msg.linear.x = float(linear_x)\n            msg.angular.z = float(angular_z)\n            self.pub.publish(msg)\n\n    node = CmdVelBlock()\n\n    while True:\n        linear_x = read_input(inputs, \"linear_x\", 0.0)\n        angular_z = read_input(inputs, \"angular_z\", 0.0)\n\n        if linear_x is None:\n            linear_x = 0.0\n\n        if angular_z is None:\n            angular_z = 0.0\n\n        node.publish_cmd(linear_x, angular_z)\n\n        synchronise()", "frequency": "30", "params": [], "ports": {"in": [{"name": "linear_x"}, {"name": "angular_z"}], "out": []}, "size": {"width": "300px", "height": "300px"}}, "position": {"x": 1101, "y": 482}}, {"id": "75b14d06-1487-4271-b093-726e49cae346", "type": "basic.output", "data": {"name": "angular_z"}, "position": {"x": 100, "y": 100}}, {"id": "a2157d82-63c2-44dd-beec-9ac6660974c6", "type": "xGMkYHflzndsoyu3dWmvKBpyq3xZlc7m26JpUfQG", "data": {}, "position": {"x": 100, "y": 100}}], "wires": [{"source": {"block": "2ff0697c-424f-4ed1-9b17-51d3d6297134", "port": "laser_ready", "name": "laser_ready"}, "target": {"block": "19775c67-2fa0-42aa-8938-1396ec00ac2a", "port": "laser_ready", "name": "laser_ready"}}, {"source": {"block": "2ff0697c-424f-4ed1-9b17-51d3d6297134", "port": "ranges", "name": "ranges"}, "target": {"block": "19775c67-2fa0-42aa-8938-1396ec00ac2a", "port": "ranges", "name": "ranges"}}, {"source": {"block": "2ff0697c-424f-4ed1-9b17-51d3d6297134", "port": "angle_min", "name": "angle_min"}, "target": {"block": "19775c67-2fa0-42aa-8938-1396ec00ac2a", "port": "angle_min", "name": "angle_min"}}, {"source": {"block": "2ff0697c-424f-4ed1-9b17-51d3d6297134", "port": "angle_increment", "name": "angle_increment"}, "target": {"block": "19775c67-2fa0-42aa-8938-1396ec00ac2a", "port": "angle_increment", "name": "angle_increment"}}, {"source": {"block": "19775c67-2fa0-42aa-8938-1396ec00ac2a", "port": "distance_ready", "name": "distance_ready"}, "target": {"block": "52d347cf-d852-4356-8cb0-13f48e935367", "port": "distance_ready", "name": "distance_ready"}}, {"source": {"block": "19775c67-2fa0-42aa-8938-1396ec00ac2a", "port": "front_distance", "name": "front_distance"}, "target": {"block": "52d347cf-d852-4356-8cb0-13f48e935367", "port": "front_distance", "name": "front_distance"}}, {"source": {"block": "52d347cf-d852-4356-8cb0-13f48e935367", "port": "linear_x", "name": "linear_x"}, "target": {"block": "19991c8c-f0ad-4b9d-adb2-9d81080b6bec", "port": "linear_x", "name": "linear_x"}}, {"source": {"block": "52d347cf-d852-4356-8cb0-13f48e935367", "port": "angular_z", "name": "angular_z"}, "target": {"block": "19991c8c-f0ad-4b9d-adb2-9d81080b6bec", "port": "angular_z", "name": "angular_z"}}, {"source": {"block": "52d347cf-d852-4356-8cb0-13f48e935367", "port": "angular_z", "name": "angular_z"}, "target": {"block": "75b14d06-1487-4271-b093-726e49cae346", "port": "output-in", "name": "output-in", "ob": "absent"}}, {"source": {"block": "a41b9299-9ca0-44ef-b6bf-9a80d484eda2", "port": "laser_ready", "name": "laser_ready"}, "target": {"block": "d185885f-5d83-409f-bdfe-c798e089fa30", "port": "laser_ready", "name": "laser_ready"}}, {"source": {"block": "a41b9299-9ca0-44ef-b6bf-9a80d484eda2", "port": "ranges", "name": "ranges"}, "target": {"block": "d185885f-5d83-409f-bdfe-c798e089fa30", "port": "ranges", "name": "ranges"}}, {"source": {"block": "a41b9299-9ca0-44ef-b6bf-9a80d484eda2", "port": "angle_min", "name": "angle_min"}, "target": {"block": "d185885f-5d83-409f-bdfe-c798e089fa30", "port": "angle_min", "name": "angle_min"}}, {"source": {"block": "a41b9299-9ca0-44ef-b6bf-9a80d484eda2", "port": "angle_increment", "name": "angle_increment"}, "target": {"block": "d185885f-5d83-409f-bdfe-c798e089fa30", "port": "angle_increment", "name": "angle_increment"}}, {"source": {"block": "d185885f-5d83-409f-bdfe-c798e089fa30", "port": "distance_ready", "name": "distance_ready"}, "target": {"block": "ec973abb-8878-413c-8503-a144496e5a81", "port": "distance_ready", "name": "distance_ready"}}, {"source": {"block": "d185885f-5d83-409f-bdfe-c798e089fa30", "port": "front_distance", "name": "front_distance"}, "target": {"block": "ec973abb-8878-413c-8503-a144496e5a81", "port": "front_distance", "name": "front_distance"}}, {"source": {"block": "ec973abb-8878-413c-8503-a144496e5a81", "port": "linear_x", "name": "linear_x"}, "target": {"block": "0b7bceb2-0c4e-4a23-bdad-81a183bb0f9b", "port": "linear_x", "name": "linear_x"}}, {"source": {"block": "ec973abb-8878-413c-8503-a144496e5a81", "port": "angular_z", "name": "angular_z"}, "target": {"block": "0b7bceb2-0c4e-4a23-bdad-81a183bb0f9b", "port": "angular_z", "name": "angular_z"}}, {"source": {"block": "ec973abb-8878-413c-8503-a144496e5a81", "port": "angular_z", "name": "angular_z"}, "target": {"block": "a7ee7690-fbd7-45d9-a9f0-4a0ea532827e", "port": "output-in", "name": "output-in", "ob": "absent"}}]}}, "dependencies": {"xGMkYHflzndsoyu3dWmvKBpyq3xZlc7m26JpUfQG": {"package": {"name": "Line Follower PID", "version": "1.0.0", "description": "A robust PID controller block.", "author": "Sarvesh Mishra", "category": "Control Systems", "tags": ["pid", "line follower", "control"], "image": ""}, "design": {"board": "Python3-Noetic", "graph": {"blocks": [{"id": "a41b9299-9ca0-44ef-b6bf-9a80d484eda2", "type": "basic.code", "data": {"code": "import rclpy\nfrom rclpy.node import Node\nfrom rclpy.qos import qos_profile_sensor_data\nfrom sensor_msgs.msg import LaserScan\n\n\ndef write_output(outputs, name, value):\n    if hasattr(outputs, \"write\"):\n        outputs.write(name, value)\n        return\n    if hasattr(outputs, \"set\"):\n        outputs.set(name, value)\n        return\n    try:\n        outputs[name] = value\n        return\n    except Exception:\n        pass\n    setattr(outputs, name, value)\n\n\ndef main(inputs, outputs, parameters, synchronise):\n    if not rclpy.ok():\n        rclpy.init(args=None)\n\n    class LaserBlock(Node):\n        def __init__(self):\n            super().__init__(\"vc_laser_scan_reader\")\n\n            self.laser_ready = False\n            self.ranges = []\n            self.angle_min = 0.0\n            self.angle_increment = 0.0\n\n            self.create_subscription(\n                LaserScan,\n                \"/turtlebot3/laser/scan\",\n                self.scan_callback,\n                qos_profile_sensor_data,\n            )\n\n        def scan_callback(self, msg):\n            self.laser_ready = True\n            self.ranges = list(msg.ranges)\n            self.angle_min = msg.angle_min\n            self.angle_increment = msg.angle_increment\n\n    node = LaserBlock()\n\n    while True:\n        rclpy.spin_once(node, timeout_sec=0.0)\n\n        write_output(outputs, \"laser_ready\", node.laser_ready)\n        write_output(outputs, \"ranges\", node.ranges)\n        write_output(outputs, \"angle_min\", node.angle_min)\n        write_output(outputs, \"angle_increment\", node.angle_increment)\n\n        synchronise()", "frequency": "30", "params": [], "ports": {"in": [], "out": [{"name": "laser_ready"}, {"name": "ranges"}, {"name": "angle_min"}, {"name": "angle_increment"}]}, "size": {"width": "542px", "height": "300px"}}, "position": {"x": 100, "y": 100}}, {"id": "d185885f-5d83-409f-bdfe-c798e089fa30", "type": "basic.code", "data": {"code": "import math\n\n\ndef read_input(inputs, name, default=None):\n    if hasattr(inputs, \"read\"):\n        return inputs.read(name)\n    if hasattr(inputs, \"get\"):\n        return inputs.get(name, default)\n    try:\n        return inputs[name]\n    except Exception:\n        return getattr(inputs, name, default)\n\n\ndef write_output(outputs, name, value):\n    if hasattr(outputs, \"write\"):\n        outputs.write(name, value)\n        return\n    if hasattr(outputs, \"set\"):\n        outputs.set(name, value)\n        return\n    try:\n        outputs[name] = value\n        return\n    except Exception:\n        pass\n    setattr(outputs, name, value)\n\n\ndef main(inputs, outputs, parameters, synchronise):\n    front_width = 0.35\n\n    while True:\n        laser_ready = read_input(inputs, \"laser_ready\", False)\n        ranges = read_input(inputs, \"ranges\", [])\n        angle_min = read_input(inputs, \"angle_min\", 0.0)\n        angle_increment = read_input(inputs, \"angle_increment\", 0.0)\n\n        front_distance = 10.0\n\n        if laser_ready and ranges is not None:\n            values = []\n\n            for i, dist in enumerate(ranges):\n                angle = angle_min + i * angle_increment\n\n                if -front_width <= angle <= front_width:\n                    if math.isfinite(dist) and dist > 0.05:\n                        values.append(dist)\n\n            if values:\n                front_distance = min(values)\n\n        write_output(outputs, \"front_distance\", front_distance)\n\n        synchronise()", "frequency": "30", "params": [], "ports": {"in": [{"name": "laser_ready"}, {"name": "ranges"}, {"name": "angle_min"}, {"name": "angle_increment"}], "out": [{"name": "distance_ready"}, {"name": "front_distance"}]}, "size": {"width": "300px", "height": "300px"}}, "position": {"x": 522, "y": 98}}, {"id": "ec973abb-8878-413c-8503-a144496e5a81", "type": "basic.code", "data": {"code": "def read_input(inputs, name, default=None):\n    if hasattr(inputs, \"read\"):\n        return inputs.read(name)\n    if hasattr(inputs, \"get\"):\n        return inputs.get(name, default)\n    try:\n        return inputs[name]\n    except Exception:\n        return getattr(inputs, name, default)\n\n\ndef write_output(outputs, name, value):\n    if hasattr(outputs, \"write\"):\n        outputs.write(name, value)\n        return\n    if hasattr(outputs, \"set\"):\n        outputs.set(name, value)\n        return\n    try:\n        outputs[name] = value\n        return\n    except Exception:\n        pass\n    setattr(outputs, name, value)\n\n\ndef main(inputs, outputs, parameters, synchronise):\n    state = \"FORWARD\"\n\n    forward_speed = 0.16\n    turn_speed = 0.45\n\n    front_stop_distance = 0.60\n    front_clear_distance = 0.90\n\n    while True:\n        front_distance = read_input(inputs, \"front_distance\", 10.0)\n\n        if front_distance is None:\n            front_distance = 10.0\n\n        linear_x = 0.0\n        angular_z = 0.0\n\n        if state == \"FORWARD\":\n            if front_distance < front_stop_distance:\n                state = \"TURN_LEFT\"\n                linear_x = 0.0\n                angular_z = turn_speed\n            else:\n                linear_x = forward_speed\n                angular_z = 0.0\n\n        elif state == \"TURN_LEFT\":\n            linear_x = 0.0\n            angular_z = turn_speed\n\n            if front_distance > front_clear_distance:\n                state = \"FORWARD\"\n                linear_x = forward_speed\n                angular_z = 0.0\n\n        write_output(outputs, \"linear_x\", linear_x)\n        write_output(outputs, \"angular_z\", angular_z)\n        write_output(outputs, \"state\", state)\n\n        synchronise()", "frequency": "30", "params": [], "ports": {"in": [{"name": "distance_ready"}, {"name": "front_distance"}], "out": [{"name": "linear_x"}, {"name": "angular_z"}]}, "size": {"width": "300px", "height": "300px"}}, "position": {"x": 993, "y": 98}}, {"id": "0b7bceb2-0c4e-4a23-bdad-81a183bb0f9b", "type": "basic.code", "data": {"code": "import rclpy\nfrom rclpy.node import Node\nfrom geometry_msgs.msg import Twist\n\n\ndef read_input(inputs, name, default=None):\n    if hasattr(inputs, \"read\"):\n        return inputs.read(name)\n    if hasattr(inputs, \"get\"):\n        return inputs.get(name, default)\n    try:\n        return inputs[name]\n    except Exception:\n        return getattr(inputs, name, default)\n\n\ndef main(inputs, outputs, parameters, synchronise):\n    if not rclpy.ok():\n        rclpy.init(args=None)\n\n    class CmdVelBlock(Node):\n        def __init__(self):\n            super().__init__(\"vc_cmd_vel_publisher\")\n            self.pub = self.create_publisher(Twist, \"/turtlebot3/cmd_vel\", 10)\n\n        def publish_cmd(self, linear_x, angular_z):\n            msg = Twist()\n            msg.linear.x = float(linear_x)\n            msg.angular.z = float(angular_z)\n            self.pub.publish(msg)\n\n    node = CmdVelBlock()\n\n    while True:\n        linear_x = read_input(inputs, \"linear_x\", 0.0)\n        angular_z = read_input(inputs, \"angular_z\", 0.0)\n\n        if linear_x is None:\n            linear_x = 0.0\n\n        if angular_z is None:\n            angular_z = 0.0\n\n        node.publish_cmd(linear_x, angular_z)\n\n        synchronise()", "frequency": "30", "params": [], "ports": {"in": [{"name": "linear_x"}, {"name": "angular_z"}], "out": []}, "size": {"width": "300px", "height": "300px"}}, "position": {"x": 1101, "y": 482}}, {"id": "a7ee7690-fbd7-45d9-a9f0-4a0ea532827e", "type": "basic.output", "data": {"name": "angular_z"}, "position": {"x": 100, "y": 100}}], "wires": [{"source": {"block": "a41b9299-9ca0-44ef-b6bf-9a80d484eda2", "port": "laser_ready", "name": "laser_ready"}, "target": {"block": "d185885f-5d83-409f-bdfe-c798e089fa30", "port": "laser_ready", "name": "laser_ready"}}, {"source": {"block": "a41b9299-9ca0-44ef-b6bf-9a80d484eda2", "port": "ranges", "name": "ranges"}, "target": {"block": "d185885f-5d83-409f-bdfe-c798e089fa30", "port": "ranges", "name": "ranges"}}, {"source": {"block": "a41b9299-9ca0-44ef-b6bf-9a80d484eda2", "port": "angle_min", "name": "angle_min"}, "target": {"block": "d185885f-5d83-409f-bdfe-c798e089fa30", "port": "angle_min", "name": "angle_min"}}, {"source": {"block": "a41b9299-9ca0-44ef-b6bf-9a80d484eda2", "port": "angle_increment", "name": "angle_increment"}, "target": {"block": "d185885f-5d83-409f-bdfe-c798e089fa30", "port": "angle_increment", "name": "angle_increment"}}, {"source": {"block": "d185885f-5d83-409f-bdfe-c798e089fa30", "port": "distance_ready", "name": "distance_ready"}, "target": {"block": "ec973abb-8878-413c-8503-a144496e5a81", "port": "distance_ready", "name": "distance_ready"}}, {"source": {"block": "d185885f-5d83-409f-bdfe-c798e089fa30", "port": "front_distance", "name": "front_distance"}, "target": {"block": "ec973abb-8878-413c-8503-a144496e5a81", "port": "front_distance", "name": "front_distance"}}, {"source": {"block": "ec973abb-8878-413c-8503-a144496e5a81", "port": "linear_x", "name": "linear_x"}, "target": {"block": "0b7bceb2-0c4e-4a23-bdad-81a183bb0f9b", "port": "linear_x", "name": "linear_x"}}, {"source": {"block": "ec973abb-8878-413c-8503-a144496e5a81", "port": "angular_z", "name": "angular_z"}, "target": {"block": "0b7bceb2-0c4e-4a23-bdad-81a183bb0f9b", "port": "angular_z", "name": "angular_z"}}, {"source": {"block": "ec973abb-8878-413c-8503-a144496e5a81", "port": "angular_z", "name": "angular_z"}, "target": {"block": "a7ee7690-fbd7-45d9-a9f0-4a0ea532827e", "port": "output-in", "name": "output-in", "ob": "absent"}}]}}, "dependencies": {}}}}