"id": "ec3d1179-d84c-4e9e-ac39-5401a98bdfb9", "type": "point", "x": 749.0104440564786, "y": 406.3020669312982}, {"id": "0499f655-a495-4529-9701-d260c9ff2351", "type": "point", "x": 1083.7326722491625, "y": 267.85592385903584}], "labels": [], "width": 3, "color": "gray", "curvyness": 50, "selectedColor": "rgb(0,192,255)"}, "07179b71-66ee-4c0e-a1f8-144189b264db": {"id": "07179b71-66ee-4c0e-a1f8-144189b264db", "type": "default", "selected": false, "source": "52d347cf-d852-4356-8cb0-13f48e935367", "sourcePort": "b61ebd42-a212-4677-860c-0c2783de5529", "target": null, "targetPort": null, "points": [{"id": "7f86a34f-ed63-46a8-a256-e5092762c242", "type": "point", "x": 1485.8159875267993, "y": 156.1892310828984}, {"id": "0dffe732-33ea-4fd3-b2b4-b24bcbd328b8", "type": "point", "selected": false, "x": 1227, "y": 627.0069427490234}, {"id": "4148a73b-017d-403c-a867-dbd683090863", "type": "point", "x": 1205, "y": 654.0069427490234}], "labels": [], "width": 3, "color": "gray", "curvyness": 50, "selectedColor": "rgb(0,192,255)"}, "001ed324-acdc-406e-bf07-bdc76f8c75fc": {"id": "001ed324-acdc-406e-bf07-bdc76f8c75fc", "type": "default", "selected": false, "source": "52d347cf-d852-4356-8cb0-13f48e935367", "sourcePort": "b61ebd42-a212-4677-860c-0c2783de5529", "target": "19991c8c-f0ad-4b9d-adb2-9d81080b6bec", "targetPort": "f6102e89-c5b8-4938-90ee-425385d72284", "points": [{"id": "53b0bfe7-22ee-45ba-a67c-254072a2de9e", "type": "point", "x": 1485.8159875267993, "y": 156.1892310828984}, {"id": "9c739aca-929d-4c27-a87f-dc5e2950495a", "type": "point", "x": 1109.0538786228094, "y": 647.7604144402937}], "labels": [], "width": 3, "color": "gray", "curvyness": 50, "selectedColor": "rgb(0,192,255)"}, "783aa9cd-884b-4a17-a727-94de6324b88e": {"id": "783aa9cd-884b-4a17-a727-94de6324b88e", "type": "default", "selected": false, "source": "52d347cf-d852-4356-8cb0-13f48e935367", "sourcePort": "7124336c-9570-4b63-b83b-2d0e5e403146", "target": "19991c8c-f0ad-4b9d-adb2-9d81080b6bec", "targetPort": "8f1f0411-1ec3-452d-90af-b82a3d62b454", "points": [{"id": "a8d110c4-14b4-4259-8ce0-155e54f64f28", "type": "point", "x": 1485.8159875267993, "y": 271.74479218104614}, {"id": "6619524e-c440-49c8-adc6-a364fcdbd9df", "type": "point", "x": 1109.0538786228094, "y": 763.3159755384415}], "labels": [], "width": 3, "color": "gray", "curvyness": 50, "selectedColor": "rgb(0,192,255)"}, "f14cbb06-5bce-4b11-924d-09c40c0145a8": {"id": "f14cbb06-5bce-4b11-924d-09c40c0145a8", "type": "default", "source": "52d347cf-d852-4356-8cb0-13f48e935367", "sourcePort": "7124336c-9570-4b63-b83b-2d0e5e403146", "target": "75b14d06-1487-4271-b093-726e49cae346", "targetPort": "a846c110-5cc7-48d2-ad8c-95fdf4704117", "points": [{"id": "d0b6ad60-607b-4ce1-826a-a70b65ed047f", "type": "point", "x": 1485.8159875267993, "y": 271.74479218104614}, {"id": "5f6494e1-058d-4270-8b13-f90db6158047", "type": "point", "selected": false, "x": 622.6164914121266, "y": -4.134175050466218}, {"id": "c4e975ba-2819-4f3a-ae45-2e0d1bf1af3e", "type": "point", "selected": false, "x": 596.7172108392449, "y": -8.118679753986498}, {"id": "d3bab245-fd92-4fe6-a222-97ba331c6c43", "type": "point", "selected": false, "x": 573.8063087940033, "y": -2.1419226987060838}, {"id": "3d235f01-34b0-43ef-96be-681baaf26754", "type": "point", "selected": false, "x": 549.8992805728817, "y": 4.830960532454387}, {"id": "eb37283d-fe7c-404d-8a90-124cf045432d", "type": "point", "x": 108.05555624868339, "y": 125.99826883973671}], "labels": [], "width": 3, "color": "gray", "curvyness": 50, "selectedColor": "rgb(0,192,255)"}}}, {"id": "a1dde559-b16e-4c9c-a4ec-49ce44a2bebd", "type": "diagram-nodes", "isSvg": false, "transformed": true, "models": {"2ff0697c-424f-4ed1-9b17-51d3d6297134": {"id": "2ff0697c-424f-4ed1-9b17-51d3d6297134", "type": "basic.code", "selected": false, "x": 100, "y": 100, "ports": [{"id": "662dad3a-78d0-4ae9-ba67-a12cf0716932", "type": "port.output", "x": 455.55554058057464, "y": 207.36978657221536, "name": "laser_ready", "alignment": "right", "parentNode": "2ff0697c-424f-4ed1-9b17-51d3d6297134", "links": ["e63e9331-a536-4654-a550-457d11eacdbd"], "in": false, "label": "laser_ready", "hideLabel": false}, {"id": "f1dc2516-a85a-40e9-9464-e0fad23b3f2a", "type": "port.output", "x": 455.55554058057464, "y": 283.7065882168096, "name": "ranges", "alignment": "right", "parentNode": "2ff0697c-424f-4ed1-9b17-51d3d6297134", "links": ["3e63a69f-c843-407c-a62e-bd6dd4b16fe2"], "in": false, "label": "ranges", "hideLabel": false}, {"id": "03ce72c7-b73b-492a-8947-75d7aca607b1", "type": "port.output", "x": 455.55554058057464, "y": 348.3680298801553, "name": "angle_min", "alignment": "right", "parentNode": "2ff0697c-424f-4ed1-9b17-51d3d6297134", "links": ["d9d7b09f-2e7b-44f7-8418-689614aecc64"], "in": false, "label": "angle_min", "hideLabel": false}, {"id": "88ca62fe-a0f6-4182-9219-d31ed4cb8a1e", "type": "port.output", "x": 455.55554058057464, "y": 413.0381961593603, "name": "angle_increment", "alignment": "right", "parentNode": "2ff0697c-424f-4ed1-9b17-51d3d6297134", "links": ["67be822e-ace6-4a09-b54e-25ee5498978f"], "in": false, "label": "angle_increment", "hideLabel": false}], "data": {"code": "import rclpy\nfrom rclpy.node import Node\nfrom rclpy.qos import qos_profile_sensor_data\nfrom sensor_msgs.msg import LaserScan\n\n\ndef write_output(outputs, name, value):\n    if hasattr(outputs, \"write\"):\n        outputs.write(name, value)\n        return\n    if hasattr(outputs, \"set\"):\n        outputs.set(name, value)\n        return\n    try:\n        outputs[name] = value\n        return\n    except Exception:\n        pass\n    setattr(outputs, name, value)\n\n\ndef main(inputs, outputs, parameters, synchronise):\n    if not rclpy.ok():\n        rclpy.init(args=None)\n\n    class LaserBlock(Node):\n        def __init__(self):\n            super().__init__(\"vc_laser_scan_reader\")\n\n            self.laser_ready = False\n            self.ranges = []\n            self.angle_min = 0.0\n            self.angle_increment = 0.0\n\n            self.create_subscription(\n                LaserScan,\n                \"/turtlebot3/laser/scan\",\n                self.scan_callback,\n                qos_profile_sensor_data,\n            )\n\n        def scan_callback(self, msg):\n            self.laser_ready = True\n            self.ranges = list(msg.ranges)\n            self.angle_min = msg.angle_min\n            self.angle_increment = msg.angle_increment\n\n    node = LaserBlock()\n\n    while True:\n        rclpy.spin_once(node, timeout_sec=0.0)\n\n        write_output(outputs, \"laser_ready\", node.laser_ready)\n        write_output(outputs, \"ranges\", node.ranges)\n        write_output(outputs, \"angle_min\", node.angle_min)\n        write_output(outputs, \"angle_increment\", node.angle_increment)\n\n        synchronise()", "frequency": "30", "params": [], "ports": {"in": [], "out": [{"name": "laser_ready"}, {"name": "ranges"}, {"name": "angle_min"}, {"name": "angle_increment"}]}, "size": {"width": "300px", "height": "300px"}}}, "19775c67-2fa0-42aa-8938-1396ec00ac2a": {"id": "19775c67-2fa0-42aa-8938-1396ec00ac2a", "type": "basic.code", "selected": false, "x": 274.9607083817433, "y": 128.8799114522821, "ports": [{"id": "447e2ac4-5080-4639-9f26-8c8144c6fcf7", "type": "port.input", "x": 275.51214855487376, "y": 236.2413340127881, "name": "laser_ready", "alignment": "left", "parentNode": "19775c67-2fa0-42aa-8938-1396ec00ac2a", "links": ["e63e9331-a536-4654-a550-457d11eacdbd"], "in": true, "label": "laser_ready", "hideLabel": false}, {"id": "a04b4a68-334c-4c43-bcbc-1e7a9ae378a0", "type": "port.input", "x": 275.51214855487376, "y": 312.57813565738235, "name": "ranges", "alignment": "left", "parentNode": "19775c67-2fa0-42aa-8938-1396ec00ac2a", "links": ["3e63a69f-c843-407c-a62e-bd6dd4b16fe2"], "in": true, "label": "ranges", "hideLabel": false}, {"id": "f7db3299-bbda-4044-9222-663d2bd49ac9", "type": "port.input", "x": 275.51214855487376, "y": 377.239577320728, "name": "angle_min", "alignment": "left", "parentNode": "19775c67-2fa0-42aa-8938-1396ec00ac2a", "links": ["d9d7b09f-2e7b-44f7-8418-689614aecc64"], "in": true, "label": "angle_min", "hideLabel": false}, {"id": "9bb3c951-21e5-45f4-96e9-02c3d4d9760a", "type": "port.input", "x": 275.51214855487376, "y": 441.90971320057463, "name": "angle_increment", "alignment": "left", "parentNode": "19775c67-2fa0-42aa-8938-1396ec00ac2a", "links": ["67be822e-ace6-4a09-b54e-25ee5498978f"], "in": true, "label": "angle_increment", "hideLabel": false}, {"id": "813b0dcf-31f5-4c85-b278-42417a5fbbba", "type": "port.output", "x": 741.510449250472, "y": 279.3576560048528, "name": "distance_ready", "alignment": "right", "parentNode": "19775c67-2fa0-42aa-8938-1396ec00ac2a", "links": ["7c7161c3-8e4e-45fe-ba2e-388c68faf8fc"], "in": false, "label": "distance_ready", "hideLabel": false}, {"id": "f9e091d7-5080-4947-a47d-a4aeca394dc3", "type": "port.output", "x": 741.510449250472, "y": 398.80205502565246, "name": "front_distance", "alignment": "right", "parentNode": "19775c67-2fa0-42aa-8938-1396ec00ac2a", "links": ["11d407d8-2c84-463a-9e60-ed4034cbe1c4"], "in": false, "label": "front_distance", "hideLabel": false}], "data": {"code": "import math\n\n\ndef read_input(inputs, name, default=None):\n    if hasattr(inputs, \"read\"):\n        return inputs.read(name)\n    if hasattr(inputs, \"get\"):\n        return inputs.get(name, default)\n    try:\n        return inputs[name]\n    except Exception:\n        return getattr(inputs, name, default)\n\n\ndef write_output(outputs, name, value):\n    if hasattr(outputs, \"write\"):\n        outputs.write(name, value)\n        return\n    if hasattr(outputs, \"set\"):\n        outputs.set(name, value)\n        return\n    try:\n        outputs[name] = value\n        return\n    except Exception:\n        pass\n    setattr(outputs, name, value)\n\n\ndef main(inputs, outputs, parameters, synchronise):\n    front_width = 0.35\n\n    while True:\n        laser_ready = read_input(inputs, \"laser_ready\", False)\n        ranges = read_input(inputs, \"ranges\", [])\n        angle_min = read_input(inputs, \"angle_min\", 0.0)\n        angle_increment = read_input(inputs, \"angle_increment\", 0.0)\n\n        front_distance = 10.0\n\n        if laser_ready and ranges is not None:\n            values = []\n\n            for i, dist in enumerate(ranges):\n                angle = angle_min + i * angle_increment\n\n                if -front_width <= angle <= front_width:\n                    if math.isfinite(dist) and dist > 0.05:\n                        values.append(dist)\n\n            if values:\n                front_distance = min(values)\n\n        write_output(outputs, \"front_distance\", front_distance)\n\n        synchronise()", "frequency": "30", "params": [], "ports": {"in": [{"name": "laser_ready"}, {"name": "ranges"}, {"name": "angle_min"}, {"name": "angle_increment"}], "out": [{"name": "distance_ready"}, {"name": "front_distance"}]}, "size": {"width": "361px", "height": "300px"}}}, "52d347cf-d852-4356-8cb0-13f48e935367": {"id": "52d347cf-d852-4356-8cb0-13f48e935367", "type": "basic.code", "selected": false, "x": 1075.6784725980456, "y": -9.581626995047273, "ports": [{"id": "200a9159-fbc7-4ba6-b289-fbef9eee4891", "type": "port.input", "x": 1076.232677443156, "y": 140.91146923351278, "name": "distance_ready", "alignment": "left", "parentNode": "52d347cf-d852-4356-8cb0-13f48e935367", "links": ["7c7161c3-8e4e-45fe-ba2e-388c68faf8fc"], "in": true, "label": "distance_ready", "hideLabel": false}, {"id": "545bd6f3-07b1-4316-b1c3-ffe6184caab7", "type": "port.input", "x": 1076.232677443156, "y": 260.35592905302923, "name": "front_distance", "alignment": "left", "parentNode": "52d347cf-d852-4356-8cb0-13f48e935367", "links": ["11d407d8-2c84-463a-9e60-ed4034cbe1c4"], "in": true, "label": "front_distance", "hideLabel": false}, {"id": "b61ebd42-a212-4677-860c-0c2783de5529", "type": "port.output", "x": 1478.3159927207926, "y": 148.6892362768918, "name": "linear_x", "alignment": "right", "parentNode": "52d347cf-d852-4356-8cb0-13f48e935367", "links": ["07179b71-66ee-4c0e-a1f8-144189b264db", "001ed324-acdc-406e-bf07-bdc76f8c75fc"], "in": false, "label": "linear_x", "hideLabel": false}, {"id": "7124336c-9570-4b63-b83b-2d0e5e403146", "type": "port.output", "x": 1478.3159927207926, "y": 264.2447973750395, "name": "angular_z", "alignment": "right", "parentNode": "52d347cf-d852-4356-8cb0-13f48e935367", "links": ["783aa9cd-884b-4a17-a727-94de6324b88e", "f14cbb06-5bce-4b11-924d-09c40c0145a8"], "in": false, "label": "angular_z", "hideLabel": false}], "data": {"code": "def read_input(inputs, name, default=None):\n    if hasattr(inputs, \"read\"):\n        return inputs.read(name)\n    if hasattr(inputs, \"get\"):\n        return inputs.get(name, default)\n    try:\n        return inputs[name]\n    except Exception:\n        return getattr(inputs, name, default)\n\n\ndef write_output(outputs, name, value):\n    if hasattr(outputs, \"write\"):\n        outputs.write(name, value)\n        return\n    if hasattr(outputs, \"set\"):\n        outputs.set(name, value)\n        return\n    try:\n        outputs[name] = value\n        return\n    except Exception:\n        pass\n    setattr(outputs, name, value)\n\n\ndef main(inputs, outputs, parameters, synchronise):\n    state = \"FORWARD\"\n\n    forward_speed = 0.16\n    turn_speed = 0.45\n\n    front_stop_distance = 0.60\n    front_clear_distance = 0.90\n\n    while True:\n        front_distance = read_input(inputs, \"front_distance\", 10.0)\n\n        if front_distance is None:\n            front_distance = 10.0\n\n        linear_x = 0.0\n        angular_z = 0.0\n\n        if state == \"FORWARD\":\n            if front_distance < front_stop_distance:\n                state = \"TURN_LEFT\"\n                linear_x = 0.0\n                angular_z = turn_speed\n            else:\n                linear_x = forward_speed\n                angular_z = 0.0\n\n        elif state == \"TURN_LEFT\":\n            linear_x = 0.0\n            angular_z = turn_speed\n\n            if front_distance > front_clear_distance:\n                state = \"FORWARD\"\n                linear_x = forward_speed\n                angular_z = 0.0\n\n        write_output(outputs, \"linear_x\", linear_x)\n        write_output(outputs, \"angular_z\", angular_z)\n        write_output(outputs, \"state\", state)\n\n        synchronise()", "frequency": "30", "params": [], "ports": {"in": [{"name": "distance_ready"}, {"name": "front_distance"}], "out": [{"name": "linear_x"}, {"name": "angular_z"}]}, "size": {"width": "300px", "height": "300px"}}}, "19991c8c-f0ad-4b9d-adb2-9d81080b6bec": {"id": "19991c8c-f0ad-4b9d-adb2-9d81080b6bec", "type": "basic.code", "selected": false, "x": 1101, "y": 482, "ports": [{"id": "f6102e89-c5b8-4938-90ee-425385d72284", "type": "port.input", "x": 1101.553883816803, "y": 640.2604196342871, "name": "linear_x", "alignment": "left", "parentNode": "19991c8c-f0ad-4b9d-adb2-9d81080b6bec", "links": ["001ed324-acdc-406e-bf07-bdc76f8c75fc"], "in": true, "label": "linear_x", "hideLabel": false}, {"id": "8f1f0411-1ec3-452d-90af-b82a3d62b454", "type": "port.input", "x": 1101.553883816803, "y": 755.8159807324349, "name": "angular_z", "alignment": "left", "parentNode": "19991c8c-f0ad-4b9d-adb2-9d81080b6bec", "links": ["783aa9cd-884b-4a17-a727-94de6324b88e"], "in": true, "label": "angular_z", "hideLabel": false}], "data": {"code": "import rclpy\nfrom rclpy.node import Node\nfrom geometry_msgs.msg import Twist\n\n\ndef read_input(inputs, name, default=None):\n    if hasattr(inputs, \"read\"):\n        return inputs.read(name)\n    if hasattr(inputs, \"get\"):\n        return inputs.get(name, default)\n    try:\n        return inputs[name]\n    except Exception:\n        return getattr(inputs, name, default)\n\n\ndef main(inputs, outputs, parameters, synchronise):\n    if not rclpy.ok():\n        rclpy.init(args=None)\n\n    class CmdVelBlock(Node):\n        def __init__(self):\n            super().__init__(\"vc_cmd_vel_publisher\")\n            self.pub = self.create_publisher(Twist, \"/turtlebot3/cmd_vel\", 10)\n\n        def publish_cmd(self, linear_x, angular_z):\n            msg = Twist()\n            msg.linear.x = float(linear_x)\n            msg.angular.z = float(angular_z)\n            self.pub.publish(msg)\n\n    node = CmdVelBlock()\n\n    while True:\n        linear_x = read_input(inputs, \"linear_x\", 0.0)\n        angular_z = read_input(inputs, \"angular_z\", 0.0)\n\n        if linear_x is None:\n            linear_x = 0.0\n\n        if angular_z is None:\n            angular_z = 0.0\n\n        node.publish_cmd(linear_x, angular_z)\n\n        synchronise()", "frequency": "30", "params": [], "ports": {"in": [{"name": "linear_x"}, {"name": "angular_z"}], "out": []}, "size": {"width": "300px", "height": "300px"}}}, "75b14d06-1487-4271-b093-726e49cae346": {"id": "75b14d06-1487-4271-b093-726e49cae346", "type": "basic.output", "x": 100, "y": 100, "ports": [{"id": "a846c110-5cc7-48d2-ad8c-95fdf4704117", "type": "port.input", "x": 100.555557167767, "y": 118.49826548391054, "name": "output-in", "alignment": "left", "parentNode": "75b14d06-1487-4271-b093-726e49cae346", "links": ["f14cbb06-5bce-4b11-924d-09c40c0145a8"], "in": true, "label": "output-in", "hideLabel": true}], "data": {"name": "angular_z"}}, "a2157d82-63c2-44dd-beec-9ac6660974c6": {"id": "a2157d82-63c2-44dd-beec-9ac6660974c6", "type": "block.package", "selected": false, "x": 100, "y": 100, "ports": [{"id": "7ce8ad9e-e4ae-4832-903e-cadd3812df8a", "type": "port.output", "x": 215.555554791571, "y": 137.22223349808098, "name": "a7ee7690-fbd7-45d9-a9f0-4a0ea532827e", "alignment": "right", "parentNode": "a2157d82-63c2-44dd-beec-9ac6660974c6", "links": [], "in": false, "label": "angular_z", "hideLabel": false}], "data": {}, "model": {"id": "de9153de-c4af-4fb5-94b6-fe59fe1e148e", "offsetX": -2.0377778317604758, "offsetY": -2.842804852665959, "zoom": 100.38888889919093, "gridSize": 0, "layers": [{"id": "b7d922dc-489a-4771-9d31-a6b9cde95855", "type": "diagram-links", "isSvg": true, "transformed": true, "models": {"e63e9331-a536-4654-a550-457d11eacdbd": {"id": "e63e9331-a536-4654-a550-457d11eacdbd", "type": "default", "selected": false, "source": "48cdb8f9-e7dc-4e20-ac70-33a8a47c8e54", "sourcePort": "662dad3a-78d0-4ae9-ba67-a12cf0716932", "target": "13b27369-710f-4ab3-9855-73a66f2085b4", "targetPort": "447e2ac4-5080-4639-9f26-8c8144c6fcf7", "points": [{"id": "a2c61a59-9db3-450b-b581-ebcd023f9412", "type": "point", "x": 705.0521245002747, "y": 214.86979722976685}, {"id": "4e5b7813-6e61-499c-8d0a-7d859ef43d53", "type": "point", "x": 530.0521245002747, "y": 212.8646092414856}], "labels": [], "width": 3, "color": "gray", "curvyness": 50, "selectedColor": "rgb(0,192,255)"}, "3e63a69f-c843-407c-a62e-bd6dd4b16fe2": {"id": "3e63a69f-c843-407c-a62e-bd6dd4b16fe2", "type": "default", "selected": false, "source": "48cdb8f9-e7dc-4e20-ac70-33a8a47c8e54", "sourcePort": "f1dc2516-a85a-40e9-9464-e0fad23b3f2a", "target": "13b27369-710f-4ab3-9855-73a66f2085b4", "targetPort": "a04b4a68-334c-4c43-bcbc-1e7a9ae378a0", "points": [{"id": "0d01481d-7227-4058-ae60-6ad5bbd37227", "type": "point", "x": 705.0521245002747, "y": 291.20661973953247}, {"id": "601e97be-4d39-459b-bf29-c13bd60d394c", "type": "point", "x": 530.0521245002747, "y": 289.2014012336731}], "labels": [], "width": 3, "color": "gray", "curvyness": 50, "selectedColor": "rgb(0,192,255)"}, "d9d7b09f-2e7b-44f7-8418-689614aecc64": {"id": "d9d7b09f-2e7b-44f7-8418-689614aecc64", "type": "default", "selected": false, "source": "48cdb8f9-e7dc-4e20-ac70-33a8a47c8e54", "sourcePort": "03ce72c7-b73b-492a-8947-75d7aca607b1", "target": "13b27369-710f-4ab3-9855-73a66f2085b4", "targetPort": "f7db3299-bbda-4044-9222-663d2bd49ac9", "points": [{"id": "8273ad92-ba04-4c89-bbcd-11ebee95ec79", "type": "point", "x": 705.0521245002747, "y": 355.86808824539185}, {"id": "783cbebb-0fce-4918-8a75-7b27d645d08d", "type": "point", "x": 530.052