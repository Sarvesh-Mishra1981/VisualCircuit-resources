82","type":"point","x":192.5,"y":364.5},{"id":"aa570841-6125-4a9d-97c3-68476d81013e","type":"point","x":378.5,"y":557.5}],"labels":[],"width":3,"color":"gray","curvyness":50,"selectedColor":"rgb(0,192,255)"},"3ff23423-89db-4495-bc80-ec747b014e77":{"id":"3ff23423-89db-4495-bc80-ec747b014e77","type":"default","selected":false,"source":"0005-ea8b023e-2944-40f6-b0fc-f14196f2db35","sourcePort":"a6d95f72-926d-4334-9737-9b6e9b4206c0","target":"c79cef3a-ccd7-46fb-b2a2-d0536cbbe45a","targetPort":"42dddbf9-3f8e-45b9-8a50-7ba984f72abf","points":[{"id":"e517fdd6-87e8-44b6-80d9-8f6da0b71dbe","type":"point","x":864,"y":37.5},{"id":"70c6e2da-8e29-486a-a19d-25fcfad41f8b","type":"point","x":884.984375,"y":143.5}],"labels":[],"width":3,"color":"gray","curvyness":50,"selectedColor":"rgb(0,192,255)"}}},{"id":"220b70ae-199a-4bc2-8a5d-05e7ec6ae5ca","type":"diagram-nodes","isSvg":false,"transformed":true,"models":{"e03ef4c2-7efc-4890-8953-ee496958da39":{"id":"e03ef4c2-7efc-4890-8953-ee496958da39","type":"basic.input","selected":false,"x":95,"y":232,"ports":[{"id":"a23d135a-c5ad-4eac-8978-9c8fdae27da3","type":"port.output","x":181,"y":251,"name":"input-out","alignment":"right","parentNode":"a0f07e9e-bd5e-4295-a3a2-5690fa4568ba","links":["1e2cd58f-7aae-41e9-bfbb-777e1296b017"],"in":false,"label":"Vels","hideLabel":true}],"data":{"name":"Vels"}},"52421c61-e648-46f3-ba0c-18fd4c0a3e43":{"id":"52421c61-e648-46f3-ba0c-18fd4c0a3e43","type":"basic.input","selected":false,"x":99,"y":338,"ports":[{"id":"80c09fc1-951c-412b-8395-f298f56faf68","type":"port.output","x":185,"y":357,"name":"input-out","alignment":"right","parentNode":"78669ed1-e751-4ec8-ae57-b87a640feb4b","links":["f13df527-0eea-46a7-ba57-c8967f56a2d6"],"in":false,"label":"Enable","hideLabel":true}],"data":{"name":"Enable"}},"67168f27-85ca-4041-bba1-6370d1e1cd61":{"id":"67168f27-85ca-4041-bba1-6370d1e1cd61","type":"basic.code","selected":true,"x":369,"y":65,"ports":[{"id":"85b9140d-79ee-46ae-942e-f103dfe70aae","type":"port.input","x":371,"y":343,"name":"Vels","alignment":"left","parentNode":"c79cef3a-ccd7-46fb-b2a2-d0536cbbe45a","links":["1e2cd58f-7aae-41e9-bfbb-777e1296b017"],"in":true,"label":"Vels","hideLabel":false},{"id":"424fe5f3-8908-46b3-81f2-47e3b7acd14f","type":"port.input","x":371,"y":550,"name":"Enable","alignment":"left","parentNode":"c79cef3a-ccd7-46fb-b2a2-d0536cbbe45a","links":["f13df527-0eea-46a7-ba57-c8967f56a2d6"],"in":true,"label":"Enable","hideLabel":false},{"id":"42dddbf9-3f8e-45b9-8a50-7ba984f72abf","type":"port.parameter","x":877.484375,"y":136,"name":"ROSTopic","alignment":"top","parentNode":"c79cef3a-ccd7-46fb-b2a2-d0536cbbe45a","links":["3ff23423-89db-4495-bc80-ec747b014e77"],"in":true,"label":"ROSTopic","hideLabel":false}],"data":{"code":"#!/usr/bin/env python3\n\nimport numpy as np\n\nimport rclpy\nfrom rclpy.node import Node\nfrom cv_bridge import CvBridge\nfrom geometry_msgs.msg import Twist\n\nbridge = CvBridge()\nvelocities = 0\n\n# ros2 node class\nclass VelPublisher(Node):\n\n    def __init__(self, topic):\n        super().__init__('vel_publisher')\n        self.publisher_ = self.create_publisher(Twist, topic, 1)\n        timer_period = 0.5  # seconds\n        self.timer = self.create_timer(timer_period, self.timer_callback)\n\n    def timer_callback(self):\n        global velocities\n        msg = Twist()\n        \n        try:\n            msg.linear.x = float(velocities[0])\n            msg.linear.y = float(velocities[1])\n            msg.linear.z = float(velocities[2])\n            msg.angular.x = float(velocities[3])\n            msg.angular.y = float(velocities[4])\n            msg.angular.z = float(velocities[5])\n        except IndexError:\n            print(\"bad length for input array\")\n            return\n        self.publisher_.publish(msg)\n\n\n\ndef main(inputs, outputs, parameters, synchronise):\n    \n    global velocities\n\n    auto_enable = False\n    try:\n        enable = inputs.read_number('Enable')\n    except Exception:\n        auto_enable = True\n\n    rclpy.init()\n    vel_publisher = VelPublisher(parameters.read_string('ROSTopic'))\n\n    try:\n\n        while auto_enable or inputs.read_number('Enable'):\n\n            velocities = inputs.read_array('Vels')\n            if velocities is not None:\n                rclpy.spin_once(vel_publisher) \n            synchronise()   \n    \n    except KeyboardInterrupt:\n\n        vel_publisher.destroy_node()\n        rclpy.shutdown()\n","frequency":"30","params":[{"name":"ROSTopic"}],"ports":{"in":[{"name":"Vels"},{"name":"Enable"}],"out":[]},"size":{"width":"988px","height":"585px"}}},"9b37f3bc-9706-4416-b93d-2a2dc22b5852":{"id":"9b37f3bc-9706-4416-b93d-2a2dc22b5852","type":"basic.constant","selected":false,"x":803,"y":-78,"ports":[{"id":"a6d95f72-926d-4334-9737-9b6e9b4206c0","type":"port.output","x":856.5,"y":30,"name":"constant-out","alignment":"bottom","parentNode":"0005-ea8b023e-2944-40f6-b0fc-f14196f2db35","links":["3ff23423-89db-4495-bc80-ec747b014e77"],"in":false,"label":"ROSTopic","hideLabel":true}],"data":{"name":"ROSTopic","value":"/cmd_vel","local":true}}}}]},"info":{"name":"ROS2MotorDriver","version":"1.0.0","description":"Controls Robot's Movement using ROS2.","author":"David Tapiador de Vera","image":"data:image/svg+xml;base64,"},"design":{"board":"Python3-Noetic","graph":{"blocks":[{"id":"e03ef4c2-7efc-4890-8953-ee496958da39","type":"basic.input","data":{"name":"Vels"},"position":{"x":95,"y":232}},{"id":"52421c61-e648-46f3-ba0c-18fd4c0a3e43","type":"basic.input","data":{"name":"Enable"},"position":{"x":99,"y":338}},{"id":"67168f27-85ca-4041-bba1-6370d1e1cd61","type":"basic.code","data":{"code":"#!/usr/bin/env python3\n\nimport numpy as np\n\nimport rclpy\nfrom rclpy.node import Node\nfrom cv_bridge import CvBridge\nfrom geometry_msgs.msg import Twist\n\nbridge = CvBridge()\nvelocities = 0\n\n# ros2 node class\nclass VelPublisher(Node):\n\n    def __init__(self, topic):\n        super().__init__('vel_publisher')\n        self.publisher_ = self.create_publisher(Twist, topic, 1)\n        timer_period = 0.5  # seconds\n        self.timer = self.create_timer(timer_period, self.timer_callback)\n\n    def timer_callback(self):\n        global velocities\n        msg = Twist()\n        \n        try:\n            msg.linear.x = float(velocities[0])\n            msg.linear.y = float(velocities[1])\n            msg.linear.z = float(velocities[2])\n            msg.angular.x = float(velocities[3])\n            msg.angular.y = float(velocities[4])\n            msg.angular.z = float(velocities[5])\n        except IndexError:\n            print(\"bad length for input array\")\n            return\n        self.publisher_.publish(msg)\n\n\n\ndef main(inputs, outputs, parameters, synchronise):\n    \n    global velocities\n\n    auto_enable = False\n    try:\n        enable = inputs.read_number('Enable')\n    except Exception:\n        auto_enable = True\n\n    rclpy.init()\n    vel_publisher = VelPublisher(parameters.read_string('ROSTopic'))\n\n    try:\n\n        while auto_enable or inputs.read_number('Enable'):\n\n            velocities = inputs.read_array('Vels')\n            if velocities is not None:\n                rclpy.spin_once(vel_publisher) \n            synchronise()   \n    \n    except KeyboardInterrupt:\n\n        vel_publisher.destroy_node()\n        rclpy.shutdown()\n","frequency":"30","params":[{"name":"ROSTopic"}],"ports":{"in":[{"name":"Vels"},{"name":"Enable"}],"out":[]},"size":{"width":"988px","height":"585px"}},"position":{"x":369,"y":65}},{"id":"9b37f3bc-9706-4416-b93d-2a2dc22b5852","type":"basic.constant","data":{"name":"ROSTopic","value":"/cmd_vel","local":true},"position":{"x":803,"y":-78}}],"wires":[{"source":{"block":"e03ef4c2-7efc-4890-8953-ee496958da39","port":"input-out","name":"Vels"},"target":{"block":"67168f27-85ca-4041-bba1-6370d1e1cd61","port":"Vels","name":"Vels"}},{"source":{"block":"52421c61-e648-46f3-ba0c-18fd4c0a3e43","port":"input-out","name":"Enable"},"target":{"block":"67168f27-85ca-4041-bba1-6370d1e1cd61","port":"Enable","name":"Enable"}},{"source":{"block":"9b37f3bc-9706-4416-b93d-2a2dc22b5852","port":"constant-out","name":"ROSTopic"},"target":{"block":"67168f27-85ca-4041-bba1-6370d1e1cd61","port":"ROSTopic","name":"ROSTopic"}}]}},"dependencies":{}},"0004-e1dc5f9c-f8f7-4b47-98a7-ce40e8b12614":{"id":"0004-e1dc5f9c-f8f7-4b47-98a7-ce40e8b12614","type":"basic.constant","selected":false,"x":100,"y":100,"ports":[{"id":"dd91d3ba-f537-4c80-ac54-9af6080f3849","type":"port.output","x":153.05555725097656,"y":207.42189025878906,"name":"constant-out","alignment":"bottom","parentNode":"0004-e1dc5f9c-f8f7-4b47-98a7-ce40e8b12614","links":["eafc7bbd-0607-4b75-9333-b7dae60ad3d6","b69b86dd-febd-4b77-a59c-8237cc889e87"],"in":false,"label":"Enable","hideLabel":true}],"data":{"name":"Enable","value":"1","local":true}}}}]},"version":"3.0","package":{"name":"Random_Test","version":"1.22.3","description":"a random test block","author":"JDErobot","image":"","category":"ROS2","tags":["face detction","ros2","motor driver"]},"design":{"board":"Python3-Noetic","graph":{"blocks":[{"id":"ec99a815-85f6-4f52-89e1-a32ab158b67f","type":"kwBsFIud9QkHbLUDdjZg3Ep5KLk2pDzSaSas6tnq","data":{},"position":{"x":531,"y":169}},{"id":"c3c7483d-8d22-4d3e-b860-00efc39f7a34","type":"vEodBp6a5avj0ae3DBHZlJUYHfHIh7u49TZvknHf","data":{},"position":{"x":771,"y":179}},{"id":"0004-e1dc5f9c-f8f7-4b47-98a7-ce40e8b12614","type":"basic.constant","data":{"name":"Enable","value":"1","local":true},"position":{"x":100,"y":100}}],"wires":[{"source":{"block":"ec99a815-85f6-4f52-89e1-a32ab158b67f","port":"c172bac0-5f49-495f-bdce-c4604eec80d7","name":"Out"},"target":{"block":"c3c7483d-8d22-4d3e-b860-00efc39f7a34","port":"e03ef4c2-7efc-4890-8953-ee496958da39","name":"Vels"}},{"source":{"block":"0004-e1dc5f9c-f8f7-4b47-98a7-ce40e8b12614","port":"constant-out","name":"Enable"},"target":{"block":"ec99a815-85f6-4f52-89e1-a32ab158b67f","port":"11a85b60-e9ef-4a22-8483-8476f06c15f2","name":"Enable"}},{"source":{"block":"0004-e1dc5f9c-f8f7-4b47-98a7-ce40e8b12614","port":"constant-out","name":"Enable"},"target":{"block":"c3c7483d-8d22-4d3e-b860-00efc39f7a34","port":"52421c61-e648-46f3-ba0c-18fd4c0a3e43","name":"Enable"}}]}},"dependencies":{"kwBsFIud9QkHbLUDdjZg3Ep5KLk2pDzSaSas6tnq":{"package":{"name":"IMU","version":"1.0.0","description":"Reads data from IMU","author":"Toshan Luktuke","image":"data:image/svg+xml;base64,"},"design":{"board":"Python3-Noetic","graph":{"blocks":[{"id":"11a85b60-e9ef-4a22-8483-8476f06c15f2","type":"basic.input","data":{"name":"Enable"},"position":{"x":217,"y":489}},{"id":"c172bac0-5f49-495f-bdce-c4604eec80d7","type":"basic.output","data":{"name":"Out"},"position":{"x":1431,"y":492}},{"id":"82b85c3f-fdb4-46f7-a02f-3dd0a08d369e","type":"basic.constant","data":{"name":"ROSTopic","value":"/mavros/imu/data","local":true},"position":{"x":808,"y":42}},{"id":"6847d652-8425-4cf7-8026-f61120b1cebd","type":"basic.code","data":{"code":"import numpy as np\nimport rospy\nimport math\nfrom sensor_msgs.msg import Imu\nfrom tf.transformations import euler_from_quaternion\n\ndata = []\n\ndef callback(msg):\n    global data\n    # Get the orientation list from the IMU sensor\n    orientation_list = [msg.orientation.x,msg.orientation.y,msg.orientation.z,msg.orientation.w]\n    # Convert orientation obtainted into values of roll, pitch and yaw\n    (roll,pitch,yaw) = euler_from_quaternion(orientation_list)\n    # Convert val;ues in Radians to Degrees\n    roll = math.degrees(roll)\n    pitch = math.degrees(pitch)\n    yaw = math.degrees(yaw)\n    # Obtain Angular Velocities from IMU sensor\n    angVel_x = msg.angular_velocity.x\n    angVel_y = msg.angular_velocity.y\n    angVel_z = msg.angular_velocity.z\n    # Store all this data in 'data' variable for use in main function\n    data = [roll, pitch, yaw, angVel_x, angVel_y, angVel_z]\n\ndef main(inputs, outputs, parameters, synchronise):\n    global data \n    auto_enable = False\n    try:\n        enable = inputs.read_number('Enable')\n    except Exception:\n        auto_enable = True\n\n    rospy.init_node('imu_vc')\n    rostopic_name = parameters.read_string(\"ROSTopic\")\n    rospy.Subscriber(rostopic_name, Imu, callback)\n\n    while ((auto_enable or inputs.read_number('Enable')) and not rospy.is_shutdown()):\n        if not data:\n            continue\n\n        outputs.share_array(\"Out\", data)\n        synchronise()","frequency":"30","params":[{"name":"ROSTopic"}],"ports":{"in":[{"name":"Enable"}],"out":[{"name":"Out"}]},"size":{"width":"852px","height":"500px"}},"position":{"x":424,"y":187}}],"wires":[{"source":{"block":"82b85c3f-fdb4-46f7-a02f-3dd0a08d369e","port":"constant-out","name":"ROSTopic"},"target":{"block":"6847d652-8425-4cf7-8026-f61120b1cebd","port":"ROSTopic","name":"ROSTopic"}},{"source":{"block":"6847d652-8425-4cf7-8026-f61120b1cebd","port":"Out","name":"Out"},"target":{"block":"c172bac0-5f49-495f-bdce-c4604eec80d7","port":"output-in","name":"output-in"}},{"source":{"block":"11a85b60-e9ef-4a22-8483-8476f06c15f2","port":"input-out","name":"Enable"},"target":{"block":"6847d652-8425-4cf7-8026-f61120b1cebd","port":"Enable","name":"Enable"}}]}},"dependencies":{}},"vEodBp6a5avj0ae3DBHZlJUYHfHIh7u49TZvknHf":{"package":{"name":"ROS2MotorDriver","version":"1.0.0","description":"Controls Robot's Movement using ROS2.","author":"David Tapiador de Vera","image":"data:image/svg+xml;base64,"},"design":{"board":"Python3-Noetic","graph":{"blocks":[{"id":"e03ef4c2-7efc-4890-8953-ee496958da39","type":"basic.input","data":{"name":"Vels"},"position":{"x":95,"y":232}},{"id":"52421c61-e648-46f3-ba0c-18fd4c0a3e43","type":"basic.input","data":{"name":"Enable"},"position":{"x":99,"y":338}},{"id":"67168f27-85ca-4041-bba1-6370d1e1cd61","type":"basic.code","data":{"code":"#!/usr/bin/env python3\n\nimport numpy as np\n\nimport rclpy\nfrom rclpy.node import Node\nfrom cv_bridge import CvBridge\nfrom geometry_msgs.msg import Twist\n\nbridge = CvBridge()\nvelocities = 0\n\n# ros2 node class\nclass VelPublisher(Node):\n\n    def __init__(self, topic):\n        super().__init__('vel_publisher')\n        self.publisher_ = self.create_publisher(Twist, topic, 1)\n        timer_period = 0.5  # seconds\n        self.timer = self.create_timer(timer_period, self.timer_callback)\n\n    def timer_callback(self):\n        global velocities\n        msg = Twist()\n        \n        try:\n            msg.linear.x = float(velocities[0])\n            msg.linear.y = float(velocities[1])\n            msg.linear.z = float(velocities[2])\n            msg.angular.x = float(velocities[3])\n            msg.angular.y = float(velocities[4])\n            msg.angular.z = float(velocities[5])\n        except IndexError:\n            print(\"bad length for input array\")\n            return\n        self.publisher_.publish(msg)\n\n\n\ndef main(inputs, outputs, parameters, synchronise):\n    \n    global velocities\n\n    auto_enable = False\n    try:\n        enable = inputs.read_number('Enable')\n    except Exception:\n        auto_enable = True\n\n    rclpy.init()\n    vel_publisher = VelPublisher(parameters.read_string('ROSTopic'))\n\n    try:\n\n        while auto_enable or inputs.read_number('Enable'):\n\n            velocities = inputs.read_array('Vels')\n            if velocities is not None:\n                rclpy.spin_once(vel_publisher) \n            synchronise()   \n    \n    except KeyboardInterrupt:\n\n        vel_publisher.destroy_node()\n        rclpy.shutdown()\n","frequency":"30","params":[{"name":"ROSTopic"}],"ports":{"in":[{"name":"Vels"},{"name":"Enable"}],"out":[]},"size":{"width":"988px","height":"585px"}},"position":{"x":369,"y":65}},{"id":"9b37f3bc-9706-4416-b93d-2a2dc22b5852","type":"basic.constant","data":{"name":"ROSTopic","value":"/cmd_vel","local":true},"position":{"x":803,"y":-78}}],"wires":[{"source":{"block":"e03ef4c2-7efc-4890-8953-ee496958da39","port":"input-out","name":"Vels"},"target":{"block":"67168f27-85ca-4041-bba1-6370d1e1cd61","port":"Vels","name":"Vels"}},{"source":{"block":"52421c61-e648-46f3-ba0c-18fd4c0a3e43","port":"input-out","name":"Enable"},"target":{"block":"67168f27-85ca-4041-bba1-6370d1e1cd61","port":"Enable","name":"Enable"}},{"source":{"block":"9b37f3bc-9706-4416-b93d-2a2dc22b5852","port":"constant-out","name":"ROSTopic"},"target":{"block":"67168f27-85ca-4041-bba1-6370d1e1cd61","port":"ROSTopic","name":"ROSTopic"}}]}},"dependencies":{}}}}