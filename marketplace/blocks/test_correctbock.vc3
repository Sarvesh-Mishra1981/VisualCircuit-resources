e7bf-40ee-bbe7-4834b367c3fb":{"id":"d61d9f5e-e7bf-40ee-bbe7-4834b367c3fb","type":"basic.input","selected":false,"x":99,"y":338,"ports":[{"id":"80c09fc1-951c-412b-8395-f298f56faf68","type":"port.output","x":185,"y":357,"name":"input-out","alignment":"right","parentNode":"78669ed1-e751-4ec8-ae57-b87a640feb4b","links":["f13df527-0eea-46a7-ba57-c8967f56a2d6"],"in":false,"label":"Enable","hideLabel":true}],"data":{"name":"Enable"}},"ac7cee24-e684-4e25-a289-3452db6b946a":{"id":"ac7cee24-e684-4e25-a289-3452db6b946a","type":"basic.code","selected":true,"x":369,"y":65,"ports":[{"id":"85b9140d-79ee-46ae-942e-f103dfe70aae","type":"port.input","x":371,"y":343,"name":"Vels","alignment":"left","parentNode":"c79cef3a-ccd7-46fb-b2a2-d0536cbbe45a","links":["1e2cd58f-7aae-41e9-bfbb-777e1296b017"],"in":true,"label":"Vels","hideLabel":false},{"id":"424fe5f3-8908-46b3-81f2-47e3b7acd14f","type":"port.input","x":371,"y":550,"name":"Enable","alignment":"left","parentNode":"c79cef3a-ccd7-46fb-b2a2-d0536cbbe45a","links":["f13df527-0eea-46a7-ba57-c8967f56a2d6"],"in":true,"label":"Enable","hideLabel":false},{"id":"42dddbf9-3f8e-45b9-8a50-7ba984f72abf","type":"port.parameter","x":877.484375,"y":136,"name":"ROSTopic","alignment":"top","parentNode":"c79cef3a-ccd7-46fb-b2a2-d0536cbbe45a","links":["3ff23423-89db-4495-bc80-ec747b014e77"],"in":true,"label":"ROSTopic","hideLabel":false}],"data":{"code":"#!/usr/bin/env python3\n\nimport numpy as np\n\nimport rclpy\nfrom rclpy.node import Node\nfrom cv_bridge import CvBridge\nfrom geometry_msgs.msg import Twist\n\nbridge = CvBridge()\nvelocities = 0\n\n# ros2 node class\nclass VelPublisher(Node):\n\n    def __init__(self, topic):\n        super().__init__('vel_publisher')\n        self.publisher_ = self.create_publisher(Twist, topic, 1)\n        timer_period = 0.5  # seconds\n        self.timer = self.create_timer(timer_period, self.timer_callback)\n\n    def timer_callback(self):\n        global velocities\n        msg = Twist()\n        \n        try:\n            msg.linear.x = float(velocities[0])\n            msg.linear.y = float(velocities[1])\n            msg.linear.z = float(velocities[2])\n            msg.angular.x = float(velocities[3])\n            msg.angular.y = float(velocities[4])\n            msg.angular.z = float(velocities[5])\n        except IndexError:\n            print(\"bad length for input array\")\n            return\n        self.publisher_.publish(msg)\n\n\n\ndef main(inputs, outputs, parameters, synchronise):\n    \n    global velocities\n\n    auto_enable = False\n    try:\n        enable = inputs.read_number('Enable')\n    except Exception:\n        auto_enable = True\n\n    rclpy.init()\n    vel_publisher = VelPublisher(parameters.read_string('ROSTopic'))\n\n    try:\n\n        while auto_enable or inputs.read_number('Enable'):\n\n            velocities = inputs.read_array('Vels')\n            if velocities is not None:\n                rclpy.spin_once(vel_publisher) \n            synchronise()   \n    \n    except KeyboardInterrupt:\n\n        vel_publisher.destroy_node()\n        rclpy.shutdown()\n","frequency":"30","params":[{"name":"ROSTopic"}],"ports":{"in":[{"name":"Vels"},{"name":"Enable"}],"out":[]},"size":{"width":"988px","height":"585px"}}},"0c753afa-c242-4338-8676-0d00a2f992e8":{"id":"0c753afa-c242-4338-8676-0d00a2f992e8","type":"basic.constant","selected":false,"x":803,"y":-78,"ports":[{"id":"a6d95f72-926d-4334-9737-9b6e9b4206c0","type":"port.output","x":856.5,"y":30,"name":"constant-out","alignment":"bottom","parentNode":"0005-ea8b023e-2944-40f6-b0fc-f14196f2db35","links":["3ff23423-89db-4495-bc80-ec747b014e77"],"in":false,"label":"ROSTopic","hideLabel":true}],"data":{"name":"ROSTopic","value":"/cmd_vel","local":true}}}}]},"info":{"name":"ROS2MotorDriver","version":"1.0.0","description":"Controls Robot's Movement using ROS2.","author":"David Tapiador de Vera","image":"data:image/svg+xml;base64,"},"design":{"board":"Python3-Noetic","graph":{"blocks":[{"id":"81f8c457-c749-45de-94b3-640c8db3d84c","type":"basic.input","data":{"name":"Vels"},"position":{"x":95,"y":232}},{"id":"d61d9f5e-e7bf-40ee-bbe7-4834b367c3fb","type":"basic.input","data":{"name":"Enable"},"position":{"x":99,"y":338}},{"id":"ac7cee24-e684-4e25-a289-3452db6b946a","type":"basic.code","data":{"code":"#!/usr/bin/env python3\n\nimport numpy as np\n\nimport rclpy\nfrom rclpy.node import Node\nfrom cv_bridge import CvBridge\nfrom geometry_msgs.msg import Twist\n\nbridge = CvBridge()\nvelocities = 0\n\n# ros2 node class\nclass VelPublisher(Node):\n\n    def __init__(self, topic):\n        super().__init__('vel_publisher')\n        self.publisher_ = self.create_publisher(Twist, topic, 1)\n        timer_period = 0.5  # seconds\n        self.timer = self.create_timer(timer_period, self.timer_callback)\n\n    def timer_callback(self):\n        global velocities\n        msg = Twist()\n        \n        try:\n            msg.linear.x = float(velocities[0])\n            msg.linear.y = float(velocities[1])\n            msg.linear.z = float(velocities[2])\n            msg.angular.x = float(velocities[3])\n            msg.angular.y = float(velocities[4])\n            msg.angular.z = float(velocities[5])\n        except IndexError:\n            print(\"bad length for input array\")\n            return\n        self.publisher_.publish(msg)\n\n\n\ndef main(inputs, outputs, parameters, synchronise):\n    \n    global velocities\n\n    auto_enable = False\n    try:\n        enable = inputs.read_number('Enable')\n    except Exception:\n        auto_enable = True\n\n    rclpy.init()\n    vel_publisher = VelPublisher(parameters.read_string('ROSTopic'))\n\n    try:\n\n        while auto_enable or inputs.read_number('Enable'):\n\n            velocities = inputs.read_array('Vels')\n            if velocities is not None:\n                rclpy.spin_once(vel_publisher) \n            synchronise()   \n    \n    except KeyboardInterrupt:\n\n        vel_publisher.destroy_node()\n        rclpy.shutdown()\n","frequency":"30","params":[{"name":"ROSTopic"}],"ports":{"in":[{"name":"Vels"},{"name":"Enable"}],"out":[]},"size":{"width":"988px","height":"585px"}},"position":{"x":369,"y":65}},{"id":"0c753afa-c242-4338-8676-0d00a2f992e8","type":"basic.constant","data":{"name":"ROSTopic","value":"/cmd_vel","local":true},"position":{"x":803,"y":-78}}],"wires":[{"source":{"block":"81f8c457-c749-45de-94b3-640c8db3d84c","port":"input-out","name":"Vels"},"target":{"block":"ac7cee24-e684-4e25-a289-3452db6b946a","port":"Vels","name":"Vels"}},{"source":{"block":"d61d9f5e-e7bf-40ee-bbe7-4834b367c3fb","port":"input-out","name":"Enable"},"target":{"block":"ac7cee24-e684-4e25-a289-3452db6b946a","port":"Enable","name":"Enable"}},{"source":{"block":"0c753afa-c242-4338-8676-0d00a2f992e8","port":"constant-out","name":"ROSTopic"},"target":{"block":"ac7cee24-e684-4e25-a289-3452db6b946a","port":"ROSTopic","name":"ROSTopic"}}]}},"dependencies":{}},"0006-5e2d4e46-25c7-4205-bdb3-c820b80b516a":{"id":"0006-5e2d4e46-25c7-4205-bdb3-c820b80b516a","type":"basic.constant","selected":false,"x":100,"y":100,"ports":[{"id":"5dc158a8-a412-49f7-a4e6-7ae2cf3771cd","type":"port.output","x":153.05555725097656,"y":207.42189025878906,"name":"constant-out","alignment":"bottom","parentNode":"0006-5e2d4e46-25c7-4205-bdb3-c820b80b516a","links":["38f22b30-6c1a-4092-bf29-f36cf506b259","bfca02d2-ecad-47af-a836-e2c1c07b8a9b"],"in":false,"label":"Enable","hideLabel":true}],"data":{"name":"Enable","value":"1","local":true}}}}]},"version":"3.0","package":{"name":"test_correctbock","version":"1.2.3","description":"a test block","author":"Jmpalza","image":"","category":"Locomotion","tags":["cv2","ros2"]},"design":{"board":"Python3-Noetic","graph":{"blocks":[{"id":"10f8aef7-0647-44e2-85cf-fe30eb28adfa","type":"gnaic3NC4dmBYhtsX8fA3mrQIxOoBCWCyiBJJqaU","data":{},"position":{"x":519,"y":166}},{"id":"631a0630-a291-401f-a74c-0b0b2c123825","type":"MuiPGOyTHIH4DH18iymIHrpBOxttIFgQ5akDDSPu","data":{},"position":{"x":744,"y":180}},{"id":"0006-5e2d4e46-25c7-4205-bdb3-c820b80b516a","type":"basic.constant","data":{"name":"Enable","value":"1","local":true},"position":{"x":100,"y":100}}],"wires":[{"source":{"block":"10f8aef7-0647-44e2-85cf-fe30eb28adfa","port":"64d9eb97-5acd-40c0-8aa3-21b712e68054","name":"Img"},"target":{"block":"631a0630-a291-401f-a74c-0b0b2c123825","port":"81f8c457-c749-45de-94b3-640c8db3d84c","name":"Vels"}},{"source":{"block":"0006-5e2d4e46-25c7-4205-bdb3-c820b80b516a","port":"constant-out","name":"Enable"},"target":{"block":"10f8aef7-0647-44e2-85cf-fe30eb28adfa","port":"d623c4a6-c5d2-424d-9d3c-ef250627fe7b","name":"Enable"}},{"source":{"block":"0006-5e2d4e46-25c7-4205-bdb3-c820b80b516a","port":"constant-out","name":"Enable"},"target":{"block":"631a0630-a291-401f-a74c-0b0b2c123825","port":"d61d9f5e-e7bf-40ee-bbe7-4834b367c3fb","name":"Enable"}}]}},"dependencies":{"gnaic3NC4dmBYhtsX8fA3mrQIxOoBCWCyiBJJqaU":{"package":{"name":"Camera","version":"2.0.0","description":"Captures Video Stream from Camera","author":"Muhammad Taha Suhail, Suhas Gopal","image":"data:image/svg+xml;base64,"},"design":{"board":"Python3-Noetic","graph":{"blocks":[{"id":"c7d7180e-33cf-49ed-b919-1232a969b0f8","type":"basic.code","data":{"code":"import cv2\n\n\ndef main(inputs, outputs, parameters, synchronise):\n    cap = cv2.VideoCapture(0)\n    auto_enable = False\n    try:\n        enable = inputs.read_number('Enable')\n    except Exception:\n        auto_enable = True\n    try:\n        while cap.isOpened() and (auto_enable or inputs.read_number('Enable')):\n            ret, frame = cap.read()\n            if not ret:\n                continue\n\n            outputs.share_image(\"Img\", frame)\n            synchronise()\n    except Exception as e:\n        print('Error:', e)\n        pass\n    finally:\n        print(\"Exiting\")\n        cap.release()","frequency":"30","params":[],"ports":{"in":[{"name":"Enable"}],"out":[{"name":"Img"}]},"size":{"width":"777px","height":"500px"}},"position":{"x":446,"y":120}},{"id":"64d9eb97-5acd-40c0-8aa3-21b712e68054","type":"basic.output","data":{"name":"Img"},"position":{"x":1128,"y":342}},{"id":"d623c4a6-c5d2-424d-9d3c-ef250627fe7b","type":"basic.input","data":{"name":"Enable"},"position":{"x":218,"y":336}}],"wires":[{"source":{"block":"c7d7180e-33cf-49ed-b919-1232a969b0f8","port":"Img","name":"Img"},"target":{"block":"64d9eb97-5acd-40c0-8aa3-21b712e68054","port":"output-in","name":"output-in"}},{"source":{"block":"d623c4a6-c5d2-424d-9d3c-ef250627fe7b","port":"input-out","name":"Enable"},"target":{"block":"c7d7180e-33cf-49ed-b919-1232a969b0f8","port":"Enable","name":"Enable"}}]}},"dependencies":{}},"MuiPGOyTHIH4DH18iymIHrpBOxttIFgQ5akDDSPu":{"package":{"name":"ROS2MotorDriver","version":"1.0.0","description":"Controls Robot's Movement using ROS2.","author":"David Tapiador de Vera","image":"data:image/svg+xml;base64,"},"design":{"board":"Python3-Noetic","graph":{"blocks":[{"id":"81f8c457-c749-45de-94b3-640c8db3d84c","type":"basic.input","data":{"name":"Vels"},"position":{"x":95,"y":232}},{"id":"d61d9f5e-e7bf-40ee-bbe7-4834b367c3fb","type":"basic.input","data":{"name":"Enable"},"position":{"x":99,"y":338}},{"id":"ac7cee24-e684-4e25-a289-3452db6b946a","type":"basic.code","data":{"code":"#!/usr/bin/env python3\n\nimport numpy as np\n\nimport rclpy\nfrom rclpy.node import Node\nfrom cv_bridge import CvBridge\nfrom geometry_msgs.msg import Twist\n\nbridge = CvBridge()\nvelocities = 0\n\n# ros2 node class\nclass VelPublisher(Node):\n\n    def __init__(self, topic):\n        super().__init__('vel_publisher')\n        self.publisher_ = self.create_publisher(Twist, topic, 1)\n        timer_period = 0.5  # seconds\n        self.timer = self.create_timer(timer_period, self.timer_callback)\n\n    def timer_callback(self):\n        global velocities\n        msg = Twist()\n        \n        try:\n            msg.linear.x = float(velocities[0])\n            msg.linear.y = float(velocities[1])\n            msg.linear.z = float(velocities[2])\n            msg.angular.x = float(velocities[3])\n            msg.angular.y = float(velocities[4])\n            msg.angular.z = float(velocities[5])\n        except IndexError:\n            print(\"bad length for input array\")\n            return\n        self.publisher_.publish(msg)\n\n\n\ndef main(inputs, outputs, parameters, synchronise):\n    \n    global velocities\n\n    auto_enable = False\n    try:\n        enable = inputs.read_number('Enable')\n    except Exception:\n        auto_enable = True\n\n    rclpy.init()\n    vel_publisher = VelPublisher(parameters.read_string('ROSTopic'))\n\n    try:\n\n        while auto_enable or inputs.read_number('Enable'):\n\n            velocities = inputs.read_array('Vels')\n            if velocities is not None:\n                rclpy.spin_once(vel_publisher) \n            synchronise()   \n    \n    except KeyboardInterrupt:\n\n        vel_publisher.destroy_node()\n        rclpy.shutdown()\n","frequency":"30","params":[{"name":"ROSTopic"}],"ports":{"in":[{"name":"Vels"},{"name":"Enable"}],"out":[]},"size":{"width":"988px","height":"585px"}},"position":{"x":369,"y":65}},{"id":"0c753afa-c242-4338-8676-0d00a2f992e8","type":"basic.constant","data":{"name":"ROSTopic","value":"/cmd_vel","local":true},"position":{"x":803,"y":-78}}],"wires":[{"source":{"block":"81f8c457-c749-45de-94b3-640c8db3d84c","port":"input-out","name":"Vels"},"target":{"block":"ac7cee24-e684-4e25-a289-3452db6b946a","port":"Vels","name":"Vels"}},{"source":{"block":"d61d9f5e-e7bf-40ee-bbe7-4834b367c3fb","port":"input-out","name":"Enable"},"target":{"block":"ac7cee24-e684-4e25-a289-3452db6b946a","port":"Enable","name":"Enable"}},{"source":{"block":"0c753afa-c242-4338-8676-0d00a2f992e8","port":"constant-out","name":"ROSTopic"},"target":{"block":"ac7cee24-e684-4e25-a289-3452db6b946a","port":"ROSTopic","name":"ROSTopic"}}]}},"dependencies":{}}}}