ra","version":"2.0.0","description":"Captures Video Stream from Camera","author":"Muhammad Taha Suhail, Suhas Gopal","image":"data:image/svg+xml;base64,"},"design":{"board":"Python3-Noetic","graph":{"blocks":[{"id":"65de94ce-7e0a-49e7-9c27-85b6858d8ddb","type":"basic.code","data":{"code":"import cv2\n\n\ndef main(inputs, outputs, parameters, synchronise):\n    cap = cv2.VideoCapture(0)\n    auto_enable = False\n    try:\n        enable = inputs.read_number('Enable')\n    except Exception:\n        auto_enable = True\n    try:\n        while cap.isOpened() and (auto_enable or inputs.read_number('Enable')):\n            ret, frame = cap.read()\n            if not ret:\n                continue\n\n            outputs.share_image(\"Img\", frame)\n            synchronise()\n    except Exception as e:\n        print('Error:', e)\n        pass\n    finally:\n        print(\"Exiting\")\n        cap.release()","frequency":"30","params":[],"ports":{"in":[{"name":"Enable"}],"out":[{"name":"Img"}]},"size":{"width":"777px","height":"500px"}},"position":{"x":446,"y":120}},{"id":"cf633039-a86b-4147-a7e8-6a6643b3d195","type":"basic.output","data":{"name":"Img"},"position":{"x":1128,"y":342}},{"id":"50f75690-66c9-4561-8b85-31d0f87417e4","type":"basic.input","data":{"name":"Enable"},"position":{"x":218,"y":336}}],"wires":[{"source":{"block":"65de94ce-7e0a-49e7-9c27-85b6858d8ddb","port":"Img","name":"Img"},"target":{"block":"cf633039-a86b-4147-a7e8-6a6643b3d195","port":"output-in","name":"output-in"}},{"source":{"block":"50f75690-66c9-4561-8b85-31d0f87417e4","port":"input-out","name":"Enable"},"target":{"block":"65de94ce-7e0a-49e7-9c27-85b6858d8ddb","port":"Enable","name":"Enable"}}]}},"dependencies":{}},"snfCRFEBaQjhymGuYnwS5d1QjPTdm0pGZgb08y3g":{"package":{"name":"ROS2MotorDriver","version":"1.0.0","description":"Controls Robot's Movement using ROS2.","author":"David Tapiador de Vera","image":"data:image/svg+xml;base64,"},"design":{"board":"Python3-Noetic","graph":{"blocks":[{"id":"88ded7e4-8338-4596-955e-55aeb33b804c","type":"basic.input","data":{"name":"Vels"},"position":{"x":95,"y":232}},{"id":"936ae812-e23d-4975-a532-a0106cdd330c","type":"basic.input","data":{"name":"Enable"},"position":{"x":99,"y":338}},{"id":"07fd3158-3023-4211-8ff0-1d49256c9d95","type":"basic.code","data":{"code":"#!/usr/bin/env python3\n\nimport numpy as np\n\nimport rclpy\nfrom rclpy.node import Node\nfrom cv_bridge import CvBridge\nfrom geometry_msgs.msg import Twist\n\nbridge = CvBridge()\nvelocities = 0\n\n# ros2 node class\nclass VelPublisher(Node):\n\n    def __init__(self, topic):\n        super().__init__('vel_publisher')\n        self.publisher_ = self.create_publisher(Twist, topic, 1)\n        timer_period = 0.5  # seconds\n        self.timer = self.create_timer(timer_period, self.timer_callback)\n\n    def timer_callback(self):\n        global velocities\n        msg = Twist()\n        \n        try:\n            msg.linear.x = float(velocities[0])\n            msg.linear.y = float(velocities[1])\n            msg.linear.z = float(velocities[2])\n            msg.angular.x = float(velocities[3])\n            msg.angular.y = float(velocities[4])\n            msg.angular.z = float(velocities[5])\n        except IndexError:\n            print(\"bad length for input array\")\n            return\n        self.publisher_.publish(msg)\n\n\n\ndef main(inputs, outputs, parameters, synchronise):\n    \n    global velocities\n\n    auto_enable = False\n    try:\n        enable = inputs.read_number('Enable')\n    except Exception:\n        auto_enable = True\n\n    rclpy.init()\n    vel_publisher = VelPublisher(parameters.read_string('ROSTopic'))\n\n    try:\n\n        while auto_enable or inputs.read_number('Enable'):\n\n            velocities = inputs.read_array('Vels')\n            if velocities is not None:\n                rclpy.spin_once(vel_publisher) \n            synchronise()   \n    \n    except KeyboardInterrupt:\n\n        vel_publisher.destroy_node()\n        rclpy.shutdown()\n","frequency":"30","params":[{"name":"ROSTopic"}],"ports":{"in":[{"name":"Vels"},{"name":"Enable"}],"out":[]},"size":{"width":"988px","height":"585px"}},"position":{"x":369,"y":65}},{"id":"56ed1ee5-bd99-4027-93c1-06ccaa624b5d","type":"basic.constant","data":{"name":"ROSTopic","value":"/cmd_vel","local":true},"position":{"x":803,"y":-78}}],"wires":[{"source":{"block":"88ded7e4-8338-4596-955e-55aeb33b804c","port":"input-out","name":"Vels"},"target":{"block":"07fd3158-3023-4211-8ff0-1d49256c9d95","port":"Vels","name":"Vels"}},{"source":{"block":"936ae812-e23d-4975-a532-a0106cdd330c","port":"input-out","name":"Enable"},"target":{"block":"07fd3158-3023-4211-8ff0-1d49256c9d95","port":"Enable","name":"Enable"}},{"source":{"block":"56ed1ee5-bd99-4027-93c1-06ccaa624b5d","port":"constant-out","name":"ROSTopic"},"target":{"block":"07fd3158-3023-4211-8ff0-1d49256c9d95","port":"ROSTopic","name":"ROSTopic"}}]}},"dependencies":{}}}}